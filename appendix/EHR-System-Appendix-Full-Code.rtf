\pard\b\f0\fs25\sa220 Appendix A.5: Authentication Routes\par
\pard\i\f0\fs20\sa100 File Path: backend/routes/auth.js\par
\pard\i\f0\fs20\sa100 Section Description: Login, logout, and current-user endpoints.\par
\pard\f0\fs20\sa100 What this file does: This file exposes the authentication endpoints used by the frontend login page and authenticated dashboards.\par
\pard\f0\fs20\sa100 How this file is used in the system: It receives login credentials from the frontend, validates them against stored password hashes, issues JWT tokens for successful sessions, records authentication events in the audit log, and returns identity information used by the dashboards.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Processes POST /api/auth/login and verifies user credentials with bcrypt.\par
\pard\f0\fs19\li360\sa70 - Updates the last_login timestamp after a successful login.\par
\pard\f0\fs19\li360\sa70 - Returns the signed JWT token and role information consumed by the frontend.\par
\pard\f0\fs19\li360\sa70 - Provides POST /api/auth/logout for session termination logging.\par
\pard\f0\fs19\li360\sa70 - Provides GET /api/auth/me so the application can retrieve the current user profile and permissions.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  const express = require('express');\line   2  const bcrypt = require('bcryptjs');\line   3  const router = express.Router();\line   4  const \{ db \} = require('../config/database');\line   5  const \{ generateToken, logAudit, authenticateToken \} = require('../middleware/auth');\line   6  \line   7  // POST /api/auth/login\line   8  router.post('/login', (req, res) => \{\line   9    const \{ email, password \} = req.body;\line  10  \line  11    if (!email || !password) \{\line  12      return res.status(400).json(\{ success: false, message: 'Email and password are required.' \});\line  13    \}\line  14  \line  15    const user = db.prepare(`\line  16      SELECT u.*, r.role_name FROM users u\line  17      JOIN roles r ON u.role_id = r.id\line  18      WHERE u.email = ? AND u.is_active = 1\line  19    `).get(email.toLowerCase().trim());\line  20  \line  21    if (!user) \{\line  22      logAudit(req, null, 'LOGIN_FAILED', 'DENIED', `Email not found: $\{email\}`);\line  23      return res.status(401).json(\{ success: false, message: 'Invalid credentials.' \});\line  24    \}\line  25  \line  26    const validPassword = bcrypt.compareSync(password, user.password_hash);\line  27    if (!validPassword) \{\line  28      logAudit(req, \{ email: user.email, role: user.role_name \}, 'LOGIN_FAILED', 'DENIED', 'Invalid password');\line  29      return res.status(401).json(\{ success: false, message: 'Invalid credentials.' \});\line  30    \}\line  31  \line  32    // Update last login\line  33    db.prepare('UPDATE users SET last_login = CURRENT_TIMESTAMP WHERE id = ?').run(user.id);\line  34  \line  35    const token = generateToken(user.id, user.role_name);\line  36    logAudit(req, \{ id: user.id, email: user.email, role: user.role_name \}, 'LOGIN', 'GRANTED', 'Successful login');\line  37  \line  38    res.json(\{\line  39      success: true,\line  40      token,\line  41      user: \{\line  42        id: user.id,\line  43        name: user.name,\line  44        email: user.email,\line  45        role: user.role_name\line  46      \}\line  47    \});\line  48  \});\line  49  \line  50  // POST /api/auth/logout\line  51  router.post('/logout', authenticateToken, (req, res) => \{\line  52    logAudit(req, req.user, 'LOGOUT', 'GRANTED', 'User logged out');\line  53    res.json(\{ success: true, message: 'Logged out successfully.' \});\line  54  \});\line  55  \line  56  // GET /api/auth/me\line  57  router.get('/me', authenticateToken, (req, res) => \{\line  58    const user = db.prepare(`\line  59      SELECT u.id, u.name, u.email, u.created_at, u.last_login, r.role_name\line  60      FROM users u JOIN roles r ON u.role_id = r.id WHERE u.id = ?\line  61    `).get(req.user.id);\line  62  \line  63    const permissions = db.prepare(`\line  64      SELECT p.permission_name FROM permissions p\line  65      JOIN role_permissions rp ON p.id = rp.permission_id\line  66      JOIN roles r ON rp.role_id = r.id\line  67      WHERE r.role_name = ?\line  68    `).all(req.user.role).map(p => p.permission_name);\line  69  \line  70    res.json(\{ success: true, user: \{ ...user, permissions \} \});\line  71  \});\line  72  \line  73  module.exports = router;\line  74  \par
