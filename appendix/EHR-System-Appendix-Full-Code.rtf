\pard\b\f0\fs25\sa220 Appendix A.1: Server Entry Point\par
\pard\i\f0\fs20\sa100 File Path: backend/server.js\par
\pard\i\f0\fs20\sa100 Section Description: Express application bootstrap and route registration.\par
\pard\f0\fs20\sa100 What this file does: This file is the main backend entry point. It starts the Express application, initializes the database schema, configures middleware, mounts the API routes, and serves the frontend files.\par
\pard\f0\fs20\sa100 How this file is used in the system: It is executed when the backend server starts. In the implemented system it acts as the integration layer that connects the authentication module, admin module, clinician module, patient module, database configuration, and static frontend delivery.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Loads environment variables and starts the HTTP server on the configured port.\par
\pard\f0\fs19\li360\sa70 - Calls initializeDatabase() so the SQLite schema exists before requests are processed.\par
\pard\f0\fs19\li360\sa70 - Registers common middleware such as CORS, JSON parsing, and request logging.\par
\pard\f0\fs19\li360\sa70 - Mounts the auth, admin, clinician, and patient route modules under /api.\par
\pard\f0\fs19\li360\sa70 - Serves the frontend directory and returns index.html for non-API routes.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  require('dotenv').config();\line   2  const express = require('express');\line   3  const cors = require('cors');\line   4  const morgan = require('morgan');\line   5  const path = require('path');\line   6  const \{ initializeDatabase \} = require('./config/database');\line   7  \line   8  // Initialize DB\line   9  initializeDatabase();\line  10  \line  11  const app = express();\line  12  const PORT = process.env.PORT || 5000;\line  13  \line  14  // Middleware\line  15  app.use(cors());\line  16  app.use(express.json());\line  17  app.use(morgan('dev'));\line  18  \line  19  // Serve frontend static files\line  20  app.use(express.static(path.join(__dirname, '..', 'frontend')));\line  21  \line  22  // API Routes\line  23  app.use('/api/auth', require('./routes/auth'));\line  24  app.use('/api/admin', require('./routes/admin'));\line  25  app.use('/api/clinician', require('./routes/clinician'));\line  26  app.use('/api/patient', require('./routes/patient'));\line  27  \line  28  // Health check\line  29  app.get('/api/health', (req, res) => \{\line  30    res.json(\{ status: 'ok', system: 'EHR RBAC System', version: '1.0.0', timestamp: new Date().toISOString() \});\line  31  \});\line  32  \line  33  // Access control test - attempt to access admin resource as other roles (demo)\line  34  app.get('/api/test/access-denied', (req, res) => \{\line  35    res.status(403).json(\{\line  36      success: false,\line  37      message: 'Access denied. This resource requires admin role.',\line  38      status: 'DENIED'\line  39    \});\line  40  \});\line  41  \line  42  // Serve frontend for all non-API routes (SPA support)\line  43  app.get('*', (req, res) => \{\line  44    if (!req.path.startsWith('/api')) \{\line  45      res.sendFile(path.join(__dirname, '..', 'frontend', 'index.html'));\line  46    \}\line  47  \});\line  48  \line  49  // Error handler\line  50  app.use((err, req, res, next) => \{\line  51    console.error(err.stack);\line  52    res.status(500).json(\{ success: false, message: 'Internal server error.' \});\line  53  \});\line  54  \line  55  app.listen(PORT, () => \{\line  56    console.log(`\line  57  \u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\line  58  \u\u\u   Secure EHR System with RBAC - Running   \u\u\u\line  59  \u\u\u   Port: $\{PORT\}                               \u\u\u\line  60  \u\u\u   URL:  http://localhost:$\{PORT\}              \u\u\u\line  61  \u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\u\line  62    `);\line  63  \});\line  64  \line  65  module.exports = app;\line  66  \par
