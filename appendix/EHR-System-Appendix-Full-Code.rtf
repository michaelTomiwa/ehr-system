\pard\b\f0\fs25\sa220 Appendix B.2: Access Denied Page\par
\pard\i\f0\fs20\sa100 File Path: frontend/access-denied.html\par
\pard\i\f0\fs20\sa100 Section Description: Frontend error page shown for unauthorized access attempts.\par
\pard\f0\fs20\sa100 What this file does: This file presents a user-friendly explanation when an authenticated user tries to open a page outside their authorised role.\par
\pard\f0\fs20\sa100 How this file is used in the system: It is reached when the frontend role guard detects that a user does not have permission to enter a protected page. It supports the RBAC usability layer by explaining the restriction and offering navigation back to an allowed location.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Explains that RBAC prevented the requested action.\par
\pard\f0\fs19\li360\sa70 - Shows the current role when user session data is available.\par
\pard\f0\fs19\li360\sa70 - Provides buttons to go back, return to the dashboard, or log out.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  <!DOCTYPE html>\line   2  <html lang="en">\line   3  <head>\line   4    <meta charset="UTF-8">\line   5    <meta name="viewport" content="width=device-width, initial-scale=1.0">\line   6    <title>Access Denied \u\u\u EHR System</title>\line   7    <link rel="stylesheet" href="/assets/css/style.css">\line   8  </head>\line   9  <body>\line  10    <div class="access-denied-page">\line  11      <div class="icon">\u\u\u\u</div>\line  12      <h1>Access Denied</h1>\line  13      <p>You do not have the required permissions to access this resource. This access attempt has been logged.</p>\line  14      <br>\line  15      <div style="display:flex; gap:12px; justify-content:center; flex-wrap:wrap; margin-top:16px;">\line  16        <button class="btn btn-primary" onclick="history.back()">\u\u\u Go Back</button>\line  17        <button class="btn btn-secondary" onclick="goToDashboard()">My Dashboard</button>\line  18        <button class="btn btn-outline" onclick="logout()">Logout</button>\line  19      </div>\line  20      <div class="card" style="margin-top:28px; max-width:380px; text-align:left;">\line  21        <div class="card-header"><h3>Why was I denied?</h3></div>\line  22        <div style="font-size:13px; color:var(--gray-700);">\line  23          <p>The EHR system uses <strong>Role-Based Access Control (RBAC)</strong> to ensure each user can only access data and functions appropriate to their role.</p>\line  24          <br>\line  25          <p id="user-info">Please contact your administrator if you believe this is an error.</p>\line  26        </div>\line  27      </div>\line  28    </div>\line  29  \line  30  <script src="/assets/js/app.js"></script>\line  31  <script>\line  32    const user = getUser();\line  33    if (user) \{\line  34      document.getElementById('user-info').innerHTML = `Your current role is <strong>$\{user.role\}</strong>. If you need access to additional resources, contact your system administrator.`;\line  35    \}\line  36    function goToDashboard() \{\line  37      if (!user) \{ window.location.href = '/'; return; \}\line  38      window.location.href = `/pages/$\{user.role\}/dashboard.html`;\line  39    \}\line  40  </script>\line  41  </body>\line  42  </html>\line  43  \par
\pard\cb0\par
