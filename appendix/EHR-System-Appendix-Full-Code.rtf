2    const appointments = db.prepare(`\line  43      SELECT a.id, a.appointment_date, a.appointment_time, a.reason, a.status, a.notes, a.created_at,\line  44        c.name as clinician_name, c.email as clinician_email\line  45      FROM appointments a\line  46      JOIN users c ON a.clinician_id = c.id\line  47      WHERE a.patient_id = ?\line  48      ORDER BY a.appointment_date DESC\line  49    `).all(req.user.id);\line  50    res.json(\{ success: true, data: appointments \});\line  51  \});\line  52  \line  53  // GET /api/patient/summary - Quick health summary\line  54  router.get('/summary', (req, res) => \{\line  55    logAudit(req, req.user, 'VIEW_HEALTH_SUMMARY', 'GRANTED');\line  56    const summary = \{\line  57      total_visits: db.prepare('SELECT COUNT(*) as c FROM medical_records WHERE patient_id = ?').get(req.user.id).c,\line  58      upcoming_appointments: db.prepare("SELECT COUNT(*) as c FROM appointments WHERE patient_id = ? AND status = 'scheduled'").get(req.user.id).c,\line  59      last_visit: db.prepare("SELECT visit_date, diagnosis FROM medical_records WHERE patient_id = ? ORDER BY visit_date DESC LIMIT 1").get(req.user.id),\line  60      next_appointment: db.prepare(`\line  61        SELECT a.appointment_date, a.appointment_time, a.reason, u.name as clinician_name\line  62        FROM appointments a JOIN users u ON a.clinician_id = u.id\line  63        WHERE a.patient_id = ? AND a.status = 'scheduled' ORDER BY a.appointment_date, a.appointment_time LIMIT 1\line  64      `).get(req.user.id),\line  65      active_medications: db.prepare(`\line  66        SELECT medications FROM medical_records WHERE patient_id = ? AND medications IS NOT NULL ORDER BY visit_date DESC LIMIT 1\line  67      `).get(req.user.id),\line  68    \};\line  69    res.json(\{ success: true, data: summary \});\line  70  \});\line  71  \line  72  module.exports = router;\line  73  \par
