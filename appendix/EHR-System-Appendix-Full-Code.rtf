\pard\b\f0\fs25\sa220 Appendix A.6: Administrative Routes\par
\pard\i\f0\fs20\sa100 File Path: backend/routes/admin.js\par
\pard\i\f0\fs20\sa100 Section Description: Admin dashboard, user management, audit logs, and records access.\par
\pard\f0\fs20\sa100 What this file does: This file implements the administrator-only backend features for governance, monitoring, and system management.\par
\pard\f0\fs20\sa100 How this file is used in the system: It is called by the admin dashboard to load system statistics, manage user accounts, inspect audit logs, review RBAC roles, and view all medical records across the platform.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Applies authenticateToken and requireRole("admin") to the whole route group.\par
\pard\f0\fs19\li360\sa70 - Returns dashboard statistics such as user counts, record counts, appointments, and denied-access totals.\par
\pard\f0\fs19\li360\sa70 - Supports user creation, update, and soft deactivation operations.\par
\pard\f0\fs19\li360\sa70 - Allows filtered retrieval of audit logs for accountability review.\par
\pard\f0\fs19\li360\sa70 - Exposes a complete records view so the administrator can inspect system-wide data.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  const express = require('express');\line   2  const bcrypt = require('bcryptjs');\line   3  const router = express.Router();\line   4  const \{ db \} = require('../config/database');\line   5  const \{ authenticateToken, requireRole, logAudit \} = require('../middleware/auth');\line   6  \line   7  // All admin routes require authentication and admin role\line   8  router.use(authenticateToken, requireRole('admin'));\line   9  \line  10  // GET /api/admin/dashboard - System statistics\line  11  router.get('/dashboard', (req, res) => \{\line  12    logAudit(req, req.user, 'VIEW_DASHBOARD', 'GRANTED');\line  13    const stats = \{\line  14      total_users: db.prepare("SELECT COUNT(*) as c FROM users").get().c,\line  15      total_patients: db.prepare("SELECT COUNT(*) as c FROM users u JOIN roles r ON u.role_id=r.id WHERE r.role_name='patient'").get().c,\line  16      total_clinicians: db.prepare("SELECT COUNT(*) as c FROM users u JOIN roles r ON u.role_id=r.id WHERE r.role_name='clinician'").get().c,\line  17      total_admins: db.prepare("SELECT COUNT(*) as c FROM users u JOIN roles r ON u.role_id=r.id WHERE r.role_name='admin'").get().c,\line  18      total_records: db.prepare("SELECT COUNT(*) as c FROM medical_records").get().c,\line  19      total_appointments: db.prepare("SELECT COUNT(*) as c FROM appointments").get().c,\line  20      upcoming_appointments: db.prepare("SELECT COUNT(*) as c FROM appointments WHERE status='scheduled'").get().c,\line  21      total_denied_access: db.prepare("SELECT COUNT(*) as c FROM audit_logs WHERE status='DENIED'").get().c,\line  22      recent_logins: db.prepare("SELECT user_email, user_role, timestamp FROM audit_logs WHERE action='LOGIN' ORDER BY timestamp DESC LIMIT 5").all(),\line  23    \};\line  24    res.json(\{ success: true, data: stats \});\line  25  \});\line  26  \line  27  // GET /api/admin/users - List all users\line  28  router.get('/users', (req, res) => \{\line  29    logAudit(req, req.user, 'VIEW_USERS', 'GRANTED');\line  30    const users = db.prepare(`\line  31      SELECT u.id, u.name, u.email, r.role_name as role, u.is_active, u.created_at, u.last_login\line  32      FROM users u JOIN roles r ON u.role_id = r.id\line  33      ORDER BY u.created_at DESC\line  34    `).all();\line  35    res.json(\{ success: true, data: users \});\line  36  \});\line  37  \line  38  // POST /api/admin/users - Create user\line  39  router.post('/users', (req, res) => \{\line  40    const \{ name, email, password, role \} = req.body;\line  41    if (!name || !email || !password || !role) \{\line  42      return res.status(400).json(\{ success: false, message: 'All fields required.' \});\line  43    \}\line  44  \line  45    const roleRow = db.prepare('SELECT id FROM roles WHERE role_name = ?').get(role);\line  46    if (!roleRow) return res.status(400).json(\{ success: false, message: 'Invalid role.' \});\line  47  \line  48    const existing = db.prepare('SELECT id FROM users WHERE email = ?').get(email.toLowerCase());\line  49    if (existing) return res.status(409).json(\{ success: false, message: 'Email already exists.' \});\line  50  \line  51    const hash = bcrypt.hashSync(password, 10);\line  52    const result = db.prepare('INSERT INTO users (name, email, password_hash, role_id) VALUES (?, ?, ?, ?)').run(name, email.toLowerCase(), hash, roleRow.id);\line  53  \line  54    if (role === 'patient') \{\line  55      db.prepare('INSERT INTO patients (user_id) VALUES (?)').run(result.lastInsertRowid);\line  56    \}\line  57  \line  58    logAudit(req, req.user, 'CREATE_USER', 'GRANTED', `Created user: $\{email\} ($\{role\})`);\line  59    res.status(201).json(\{ success: true, message: 'User created successfully.', userId: result.lastInsertRowid \});\line  60  \});\line  61  \line  62  // PUT /api/admin/users/:id - Update user\line  63  router.put('/users/:id', (req, res) => \{\line  64    const \{ name, email, role, is_active \} = req.body;\line  65    const userId = req.params.id;\line  66  \line  67    const user = db.prepare('SELECT * FROM users WHERE id = ?').get(userId);\line  68    if (!user) return res.status(404).json(\{ success: false, message: 'User not found.' \});\line  69  \line  70    let roleId = user.role_id;\line  71    if (role) \{\line  72      const roleRow = db.prepare('SELECT id FROM roles WHERE role_name = ?').get(role);\line  73      if (!roleRow) return res.status(400).json(\{ success: false, message: 'Invalid role.' \});\line  74      roleId = roleRow.id;\line  75    \}\line  76  \line  77    db.prepare('UPDATE users SET name=?, email=?, role_id=?, is_active=? WHERE id=?').run(\line  78      name || user.name,\line  79      email || user.email,\line  80      roleId,\line  81      is_active !== undefined ? is_active : user.is_active,\line  82      userId\line  83    );\line  84  \line  85    logAudit(req, req.user, 'UPDATE_USER', 'GRANTED', `Updated user ID: $\{userId\}`);\line  86    res.json(\{ success: true, message: 'User updated successfully.' \});\line  87  \});\line  88  \line  89  // DELETE /api/admin/users/:id - Deactivate user\line  90  router.delete('/users/:id', (req, res) => \{\line  91    const userId = req.params.id;\line  92    if (parseInt(userId) === req.user.id) \{\line  93      return res.status(400).json(\{ success: false, message: 'Cannot deactivate your own account.' \});\line  94    \}\line  95    db.prepare('UPDATE users SET is_active = 0 WHERE id = ?').run(userId);\line  96    logAudit(req, req.user, 'DEACTIVATE_USER', 'GRANTED', `Deactivated user ID: $\{userId\}`);\line  97    res.json(\{ success: true, message: 'User deactivated successfully.' \});\line  98  \});\line  99  \line 100  // GET /api/admin/audit-logs - View audit logs\line 101  router.get('/audit-logs', (req, res) => \{\line 102    logAudit(req, req.user, 'VIEW_AUDIT_LOGS', 'GRANTED');\line 103    const page = parseInt(req.query.page) || 1;\line 104    const limit = parseInt(req.query.limit) || 50;\line 105    const offset = (page - 1) * limit;\line 106    const filter = req.query.status || '';\line 107  \line 108    let query = 'SELECT * FROM audit_logs';\line 109    let params = [];\line 110    if (filter) \{ query += ' WHERE status = ?'; params.push(filter.toUpperCase()); \}\line 111    query += ' ORDER BY timestamp DESC LIMIT ? OFFSET ?';\line 112    params.push(limit, offset);\line 113  \line 114    const logs = db.prepare(query).all(...params);\line 115    const total = db.prepare('SELECT COUNT(*) as c FROM audit_logs' + (filter ? ' WHERE status=?' : '')).get(...(filter ? [filter.toUpperCase()] : [])).c;\line 116    res.json(\{ success: true, data: logs, total, page, limit \});\line 117  \});\line 118  \line 119  // GET /api/admin/roles - List roles and permissions\line 120  router.get('/roles', (req, res) => \{\line 121    const roles = db.prepare('SELECT * FROM roles').all();\line 122    const result = roles.map(r => \{\line 123      const perms = db.prepare(`\line 124        SELECT p.permission_name, p.description FROM permissions p\line 125        JOIN role_permissions rp ON p.id = rp.permission_id WHERE rp.role_id = ?\line 126      `).all(r.id);\line 127      return \{ ...r, permissions: perms \};\line 128    \});\line 129    res.json(\{ success: true, data: result \});\line 130  \});\line 131  \line 132  // GET /api/admin/all-records - View all patient records\line 133  router.get('/all-records', (req, res) => \{\line 134    logAudit(req, req.user, 'VIEW_ALL_RECORDS', 'GRANTED');\line 135    const records = db.prepare(`\line 136      SELECT mr.*, \line 137        p.name as patient_name, p.email as patient_email,\line 138        c.name as clinician_name\line 139      FROM medical_records mr\line 140      JOIN users p ON mr.patient_id = p.id\line 141      JOIN users c ON mr.clinician_id = c.id\line 142      ORDER BY mr.created_at DESC\line 143    `).all();\line 144    res.json(\{ success: true, data: records \});\line 145  \});\line 146  \line 147  module.exports = router;\line 148  \par
