\pard\b\f0\fs25\sa220 Appendix B.5: Administrator Dashboard\par
\pard\i\f0\fs20\sa100 File Path: frontend/pages/admin/dashboard.html\par
\pard\i\f0\fs20\sa100 Section Description: Admin frontend for user management, logs, and system monitoring.\par
\pard\f0\fs20\sa100 What this file does: This file defines the administrator web interface for system-wide control and monitoring.\par
\pard\f0\fs20\sa100 How this file is used in the system: After admin login, this dashboard consumes the admin API endpoints to display system statistics, recent logins, user management tools, medical records, audit logs, and role-permission summaries.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Contains dashboard, user management, all-records, audit-log, and roles-permissions sections.\par
\pard\f0\fs19\li360\sa70 - Loads data dynamically from the protected admin endpoints.\par
\pard\f0\fs19\li360\sa70 - Provides modal-driven user creation and editing actions.\par
\pard\f0\fs19\li360\sa70 - Supports user deactivation and audit-log filtering within the same page.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  <!DOCTYPE html>\line   2  <html lang="en">\line   3  <head>\line   4    <meta charset="UTF-8">\line   5    <meta name="viewport" content="width=device-width, initial-scale=1.0">\line   6    <title>Admin Dashboard \u\u\u SecureEHR</title>\line   7    <link rel="stylesheet" href="/assets/css/style.css">\line   8    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">\line   9  </head>\line  10  <body>\line  11  <div class="dashboard-layout">\line  12  \line  13    <!-- SIDEBAR -->\line  14    <aside class="sidebar">\line  15      <div class="sidebar-header">\line  16        <div class="sidebar-logo">\line  17          <div class="logo-icon">\u\u\u\u</div>\line  18          <div class="sidebar-logo-text"><h2>SecureEHR</h2><p>Admin Panel</p></div>\line  19        </div>\line  20      </div>\line  21      <div class="sidebar-user">\line  22        <div class="user-avatar"></div>\line  23        <div class="sidebar-user-info">\line  24          <div class="name sidebar-user-name"></div>\line  25          <div class="role sidebar-user-role"></div>\line  26        </div>\line  27      </div>\line  28      <nav class="sidebar-nav">\line  29        <div class="nav-section-title">Main</div>\line  30        <div class="nav-item active" data-page="dashboard" onclick="showSection('dashboard')"><span class="icon">\u\u\u\u</span> Dashboard</div>\line  31        <div class="nav-section-title">Management</div>\line  32        <div class="nav-item" data-page="users" onclick="showSection('users')"><span class="icon">\u\u\u\u</span> User Management</div>\line  33        <div class="nav-item" data-page="records" onclick="showSection('records')"><span class="icon">\u\u\u\u</span> All Records</div>\line  34        <div class="nav-section-title">Security</div>\line  35        <div class="nav-item" data-page="audit" onclick="showSection('audit')"><span class="icon">\u\u\u\u</span> Audit Logs</div>\line  36        <div class="nav-item" data-page="roles" onclick="showSection('roles')"><span class="icon">\u\u\u\u\u\u\u</span> Roles & Permissions</div>\line  37      </nav>\line  38      <div class="sidebar-footer">\line  39        <button class="logout-btn" onclick="logout()"><span>\u\u\u\u</span> Sign Out</button>\line  40      </div>\line  41    </aside>\line  42  \line  43    <!-- MAIN CONTENT -->\line  44    <main class="main-content">\line  45      <div class="topbar">\line  46        <div class="topbar-title"><h1 id="section-title">Dashboard</h1><p id="section-subtitle">System overview and statistics</p></div>\line  47        <div style="display:flex; align-items:center; gap:12px;">\line  48          <span class="badge badge-admin">Administrator</span>\line  49          <span class="topbar-user-name" style="font-weight:600; font-size:13px;"></span>\line  50        </div>\line  51      </div>\line  52  \line  53      <div class="page-content">\line  54  \line  55        <!-- DASHBOARD SECTION -->\line  56        <section id="sec-dashboard">\line  57          <div class="stats-grid" id="stats-grid">\line  58            <div class="page-loader"><div class="spinner"></div></div>\line  59          </div>\line  60          <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">\line  61            <div class="card">\line  62              <div class="card-header"><div><h3>Recent Logins</h3><p>Last 5 system logins</p></div></div>\line  63              <div id="recent-logins"><div class="page-loader"><div class="spinner"></div></div></div>\line  64            </div>\line  65            <div class="card">\line  66              <div class="card-header"><div><h3>Access Statistics</h3><p>RBAC enforcement summary</p></div></div>\line  67              <div id="access-stats"></div>\line  68            </div>\line  69          </div>\line  70        </section>\line  71  \line  72        <!-- USERS SECTION -->\line  73        <section id="sec-users" style="display:none;">\line  74          <div class="card">\line  75            <div class="card-header">\line  76              <div><h3>User Management</h3><p>Create and manage system users</p></div>\line  77              <button class="btn btn-primary btn-sm" onclick="openCreateUserModal()">+ Add User</button>\line  78            </div>\line  79            <div class="search-bar">\line  80              <input type="text" id="user-search" placeholder="Search users by name or email..." oninput="filterUsers()">\line  81              <select id="role-filter" onchange="filterUsers()" style="padding:9px 14px; border:1.5px solid #d1d5db; border-radius:8px; font-size:13px;">\line  82                <option value="">All Roles</option>\line  83                <option value="admin">Admin</option>\line  84                <option value="clinician">Clinician</option>\line  85                <option value="patient">Patient</option>\line  86              </select>\line  87            </div>\line  88            <div class="table-container">\line  89              <table>\line  90                <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Status</th><th>Created</th><th>Last Login</th><th>Actions</th></tr></thead>\line  91                <tbody id="users-table-body"></tbody>\line  92              </table>\line  93            </div>\line  94          </div>\line  95        </section>\line  96  \line  97        <!-- ALL RECORDS SECTION -->\line  98        <section id="sec-records" style="display:none;">\line  99          <div class="card">\line 100            <div class="card-header"><div><h3>All Medical Records</h3><p>System-wide patient health records</p></div></div>\line 101            <div class="table-container">\line 102              <table>\line 103                <thead><tr><th>Patient</th><th>Clinician</th><th>Visit Date</th><th>Diagnosis</th><th>Medications</th><th>Created</th></tr></thead>\line 104                <tbody id="records-table-body"></tbody>\line 105              </table>\line 106            </div>\line 107          </div>\line 108        </section>\line 109  \line 110        <!-- AUDIT LOGS SECTION -->\line 111        <section id="sec-audit" style="display:none;">\line 112          <div class="card">\line 113            <div class="card-header">\line 114              <div><h3>Audit Logs</h3><p>Complete system activity trail for accountability</p></div>\line 115              <select id="audit-filter" onchange="loadAuditLogs()" style="padding:9px 14px; border:1.5px solid #d1d5db; border-radius:8px; font-size:13px;">\line 116                <option value="">All Events</option>\line 117                <option value="GRANTED">Access Granted</option>\line 118                <option value="DENIED">Access Denied</option>\line 119              </select>\line 120            </div>\line 121            <div class="table-container">\line 122              <table>\line 123                <thead><tr><th>Time</th><th>User</th><th>Role</th><th>Action</th><th>Resource</th><th>Method</th><th>Status</th><th>IP Address</th></tr></thead>\line 124                <tbody id="audit-table-body"></tbody>\line 125              </table>\line 126            </div>\line 127            <div style="margin-top:16px; display:flex; justify-content:center; gap:8px;" id="audit-pagination"></div>\line 128          </div>\line 129        </section>\line 130  \line 131        <!-- ROLES & PERMISSIONS SECTION -->\line 132        <section id="sec-roles" style="display:none;">\line 133          <div id="roles-container"></div>\line 134        </section>\line 135  \line 136      </div>\line 137    </main>\line 138  </div>\line 139  \line 140  <!-- Create/Edit User Modal -->\line 141  <div id="user-modal" class="modal-overlay" style="display:none;">\line 142    <div class="modal">\line 143      <div class="modal-header">\line 144        <h3 id="user-modal-title">Create New User</h3>\line 145        <button class="modal-close" onclick="closeModal('user-modal')">\u\u\u</button>\line 146      </div>\line 147      <div class="modal-body">\line 148        <div id="user-form-alert" style="display:none;"></div>\line 149        <div class="form-grid">\line 150          <div class="form-group"><label>Full Name</label><input type="text" id="u-name" placeholder="e.g. Dr. John Smith" required></div>\line 151          <div class="form-group"><label>Email Address</label><input type="email" id="u-email" placeholder="user@example.com" required></div>\line 152          <div class="form-group"><label>Password</label><input type="password" id="u-password" placeholder="Min 8 characters"></div>\line 153          <div class="form-group"><label>Role</label>\line 154            <select id="u-role">\line 155              <option value="patient">Patient</option>\line 156              <option value="clinician">Clinician</option>\line 157              <option value="admin">Administrator</option>\line 158            </select>\line 159          </div>\line 160        </div>\line 161      </div>\line 162      <div class="modal-footer">\line 163        <button class="btn btn-secondary" onclick="closeModal('user-modal')">Cancel</button>\line 164        <button class="btn btn-primary" id="user-modal-save" onclick="saveUser()">Create User</button>\line 165      </div>\line 166    </div>\line 167  </div>\line 168  \line 169  <script src="/assets/js/app.js"></script>\line 170  <script>\line 171    let allUsers = [];\line 172    let currentEditingUserId = null;\line 173    let auditPage = 1;\line 174  \line 175    if (!requireAuth(['admin'])) throw new Error('auth');\line 176    initSidebar('dashboard');\line 177  \line 178    function showSection(name) \{\line 179      ['dashboard','users','records','audit','roles'].forEach(s => \{\line 180        document.getElementById(`sec-$\{s\}`).style.display = s === name ? 'block' : 'none';\line 181      \});\line 182      document.querySelectorAll('.nav-item').forEach(el => el.classList.toggle('active', el.dataset.page === name));\line 183  \line 184      const titles = \{\line 185        dashboard: ['Dashboard', 'System overview and statistics'],\line 186        users: ['User Management', 'Manage system users and their roles'],\line 187        records: ['Medical Records', 'View all patient health records'],\line 188        audit: ['Audit Logs', 'Complete system activity trail'],\line 189        roles: ['Roles & Permissions', 'View RBAC role definitions']\line 190      \};\line 191      document.getElementById('section-title').textContent = titles[name][0];\line 192      document.getElementById('section-subtitle').textContent = titles[name][1];\line 193  \line 194      if (name === 'users') loadUsers();\line 195      if (name === 'records') loadAllRecords();\line 196      if (name === 'audit') loadAuditLogs();\line 197      if (name === 'roles') loadRoles();\line 198    \}\line 199  \line 200    async function loadDashboard() \{\line 201      const res = await api.get('/admin/dashboard');\line 202      if (!res || !res.ok) return;\line 203      const d = res.data.data;\line 204  \line 205      document.getElementById('stats-grid').innerHTML = `\line 206        <div class="stat-card"><div class="stat-icon blue">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.total_users\}</div><div class="label">Total Users</div></div></div>\line 207        <div class="stat-card"><div class="stat-icon green">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.total_clinicians\}</div><div class="label">Clinicians</div></div></div>\line 208        <div class="stat-card"><div class="stat-icon blue">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.total_patients\}</div><div class="label">Patients</div></div></div>\line 209        <div class="stat-card"><div class="stat-icon green">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.total_records\}</div><div class="label">Medical Records</div></div></div>\line 210        <div class="stat-card"><div class="stat-icon yellow">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.upcoming_appointments\}</div><div class="label">Upcoming Appointments</div></div></div>\line 211        <div class="stat-card"><div class="stat-icon red">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.total_denied_access\}</div><div class="label">Access Denied Events</div></div></div>\line 212      `;\line 213  \line 214      const logins = d.recent_logins;\line 215      document.getElementById('recent-logins').innerHTML = logins.length ? `\line 216        <div class="table-container"><table>\line 217          <thead><tr><th>User</th><th>Role</th><th>Time</th></tr></thead>\line 218          <tbody>$\{logins.map(l => `<tr><td>$\{l.user_email||'\u\u\u'\}</td><td>$\{l.user_role ? roleBadge(l.user_role) : '\u\u\u'\}</td><td>$\{formatDateTime(l.timestamp)\}</td></tr>`).join('')\}</tbody>\line 219        </table></div>` : emptyState('\u\u\u\u','No logins yet','');\line 220  \line 221      document.getElementById('access-stats').innerHTML = `\line 222        <div style="padding:10px 0;">\line 223          <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--gray-100);">\line 224            <span style="font-size:13px; font-weight:500;">Total Administrators</span>\line 225            <span class="badge badge-admin">$\{d.total_admins\}</span>\line 226          </div>\line 227          <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--gray-100);">\line 228            <span style="font-size:13px; font-weight:500;">Total Clinicians</span>\line 229            <span class="badge badge-clinician">$\{d.total_clinicians\}</span>\line 230          </div>\line 231          <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--gray-100);">\line 232            <span style="font-size:13px; font-weight:500;">Total Patients</span>\line 233            <span class="badge badge-patient">$\{d.total_patients\}</span>\line 234          </div>\line 235          <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--gray-100);">\line 236            <span style="font-size:13px; font-weight:500;">Access Denied Events</span>\line 237            <span class="badge badge-danger">$\{d.total_denied_access\}</span>\line 238          </div>\line 239          <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0;">\line 240            <span style="font-size:13px; font-weight:500;">Total Appointments</span>\line 241            <span class="badge badge-info">$\{d.total_appointments\}</span>\line 242          </div>\line 243        </div>`;\line 244    \}\line 245  \line 246    async function loadUsers() \{\line 247      document.getElementById('users-table-body').innerHTML = '<tr><td colspan="7" style="text-align:center; padding:30px;">Loading...</td></tr>';\line 248      const res = await api.get('/admin/users');\line 249      if (!res || !res.ok) return;\line 250      allUsers = res.data.data;\line 251      renderUsers(allUsers);\line 252    \}\line 253  \line 254    function renderUsers(users) \{\line 255      const tbody = document.getElementById('users-table-body');\line 256      if (!users.length) \{ tbody.innerHTML = `<tr><td colspan="7">$\{emptyState('\u\u\u\u','No users found','')\}</td></tr>`; return; \}\line 257      tbody.innerHTML = users.map(u => `\line 258        <tr>\line 259          <td><strong>$\{u.name\}</strong></td>\line 260          <td>$\{u.email\}</td>\line 261          <td>$\{roleBadge(u.role)\}</td>\line 262          <td>$\{u.is_active ? '<span class="badge badge-success">Active</span>' : '<span class="badge badge-danger">Inactive</span>'\}</td>\line 263          <td>$\{formatDate(u.created_at)\}</td>\line 264          <td>$\{u.last_login ? formatDateTime(u.last_login) : '<span style="color:var(--gray-400)">Never</span>'\}</td>\line 265          <td style="display:flex; gap:6px; flex-wrap:wrap;">\line 266            <button class="btn btn-outline btn-sm" onclick="openEditUser($\{u.id\})">Edit</button>\line 267            $\{u.is_active ? `<button class="btn btn-danger btn-sm" onclick="deactivateUser($\{u.id\},'$\{u.name\}')">Deactivate</button>` : ''\}\line 268          </td>\line 269        </tr>`).join('');\line 270    \}\line 271  \line 272    function filterUsers() \{\line 273      const q = document.getElementById('user-search').value.toLowerCase();\line 274      const role = document.getElementById('role-filter').value;\line 275      renderUsers(allUsers.filter(u =>\line 276        (u.name.toLowerCase().includes(q) || u.email.toLowerCase().includes(q)) &&\line 277        (!role || u.role === role)\line 278      ));\line 279    \}\line 280  \line 281    function openCreateUserModal() \{\line 282      currentEditingUserId = null;\line 283      document.getElementById('user-modal-title').textContent = 'Create New User';\line 284      document.getElementById('user-modal-save').textContent = 'Create User';\line 285      ['u-name','u-email','u-password'].forEach(id => document.getElementById(id).value = '');\line 286      document.getElementById('u-role').value = 'patient';\line 287      document.getElementById('u-password').placeholder = 'Min 8 characters (required)';\line 288      document.getElementById('user-form-alert').style.display = 'none';\line 289      openModal('user-modal');\line 290    \}\line 291  \line 292    function openEditUser(userId) \{\line 293      const user = allUsers.find(u => u.id === userId);\line 294      if (!user) return;\line 295      currentEditingUserId = userId;\line 296      document.getElementById('user-modal-title').textContent = 'Edit User';\line 297      document.getElementById('user-modal-save').textContent = 'Update User';\line 298      document.getElementById('u-name').value = user.name;\line 299      document.getElementById('u-email').value = user.email;\line 300      document.getElementById('u-password').value = '';\line 301      document.getElementById('u-password').placeholder = 'Leave blank to keep current password';\line 302      document.getElementById('u-role').value = user.role;\line 303      document.getElementById('user-form-alert').style.display = 'none';\line 304      openModal('user-modal');\line 305    \}\line 306  \line 307    async function saveUser() \{\line 308      const alertDiv = document.getElementById('user-form-alert');\line 309      const name = document.getElementById('u-name').value.trim();\line 310      const email = document.getElementById('u-email').value.trim();\line 311      const password = document.getElementById('u-password').value;\line 312      const role = document.getElementById('u-role').value;\line 313  \line 314      if (!name || !email || (!currentEditingUserId && !password)) \{\line 315        alertDiv.className = 'alert alert-error';\line 316        alertDiv.textContent = 'Please fill in all required fields.';\line 317        alertDiv.style.display = 'flex';\line 318        return;\line 319      \}\line 320  \line 321      let res;\line 322      if (currentEditingUserId) \{\line 323        res = await api.put(`/admin/users/$\{currentEditingUserId\}`, \{ name, email, role \});\line 324      \} else \{\line 325        res = await api.post('/admin/users', \{ name, email, password, role \});\line 326      \}\line 327  \line 328      if (res && res.ok) \{\line 329        closeModal('user-modal');\line 330        showToast(currentEditingUserId ? 'User updated successfully.' : 'User created successfully.', 'success');\line 331        loadUsers();\line 332      \} else \{\line 333        alertDiv.className = 'alert alert-error';\line 334        alertDiv.textContent = res?.data?.message || 'Operation failed.';\line 335        alertDiv.style.display = 'flex';\line 336      \}\line 337    \}\line 338  \line 339    async function deactivateUser(id, name) \{\line 340      if (!confirm(`Deactivate user "$\{name\}"? They will no longer be able to log in.`)) return;\line 341      const res = await api.delete(`/admin/users/$\{id\}`);\line 342      if (res && res.ok) \{\line 343        showToast('User deactivated.', 'success');\line 344        loadUsers();\line 345      \} else \{\line 346        showToast(res?.data?.message || 'Failed to deactivate.', 'error');\line 347      \}\line 348    \}\line 349  \line 350    async function loadAllRecords() \{\line 351      document.getElementById('records-table-body').innerHTML = '<tr><td colspan="6" style="text-align:center;padding:30px;">Loading...</td></tr>';\line 352      const res = await api.get('/admin/all-records');\line 353      if (!res || !res.ok) return;\line 354      const records = res.data.data;\line 355      document.getElementById('records-table-body').innerHTML = records.length ?\line 356        records.map(r => `<tr>\line 357          <td><strong>$\{r.patient_name\}</strong><br><span style="color:var(--gray-500); font-size:12px;">$\{r.patient_email\}</span></td>\line 358          <td>$\{r.clinician_name\}</td>\line 359          <td>$\{formatDate(r.visit_date)\}</td>\line 360          <td>$\{r.diagnosis || '\u\u\u'\}</td>\line 361          <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">$\{r.medications || '\u\u\u'\}</td>\line 362          <td>$\{formatDateTime(r.created_at)\}</td>\line 363        </tr>`).join('') :\line 364        `<tr><td colspan="6">$\{emptyState('\u\u\u\u','No records','')\}</td></tr>`;\line 365    \}\line 366  \line 367    async function loadAuditLogs() \{\line 368      const filter = document.getElementById('audit-filter').value;\line 369      document.getElementById('audit-table-body').innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;">Loading...</td></tr>';\line 370      const res = await api.get(`/admin/audit-logs?limit=100&status=$\{filter\}`);\line 371      if (!res || !res.ok) return;\line 372      const logs = res.data.data;\line 373      document.getElementById('audit-table-body').innerHTML = logs.length ?\line 374        logs.map(l => `<tr>\line 375          <td style="white-space:nowrap;">$\{formatDateTime(l.timestamp)\}</td>\line 376          <td>$\{l.user_email || '<span style="color:var(--gray-400)">Unknown</span>'\}</td>\line 377          <td>$\{l.user_role ? roleBadge(l.user_role) : '\u\u\u'\}</td>\line 378          <td><code style="font-size:11px; background:var(--gray-100); padding:2px 6px; border-radius:4px;">$\{l.action\}</code></td>\line 379          <td style="font-size:12px; color:var(--gray-600); max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">$\{l.resource || '\u\u\u'\}</td>\line 380          <td><span class="badge badge-gray">$\{l.method || '\u\u\u'\}</span></td>\line 381          <td>$\{l.status === 'GRANTED' ? '<span class="log-status-granted">\u\u\u GRANTED</span>' : '<span class="log-status-denied">\u\u\u DENIED</span>'\}</td>\line 382          <td style="font-size:12px; font-family:monospace;">$\{l.ip_address || '\u\u\u'\}</td>\line 383        </tr>`).join('') :\line 384        `<tr><td colspan="8">$\{emptyState('\u\u\u\u','No logs','')\}</td></tr>`;\line 385    \}\line 386  \line 387    async function loadRoles() \{\line 388      const res = await api.get('/admin/roles');\line 389      if (!res || !res.ok) return;\line 390      const roles = res.data.data;\line 391      const roleColors = \{ admin: '#7c3aed', clinician: '#1e40af', patient: '#065f46' \};\line 392      document.getElementById('roles-container').innerHTML = `\line 393        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap:20px;">\line 394          $\{roles.map(r => `\line 395            <div class="card">\line 396              <div class="card-header">\line 397                <div style="display:flex; align-items:center; gap:10px;">\line 398                  <div style="width:40px;height:40px;border-radius:10px;background:$\{roleColors[r.role_name]||'#374151'\};display:flex;align-items:center;justify-content:center;font-size:20px;">\line 399                    $\{r.role_name === 'admin' ? '\u\u\u\u\u\u\u' : r.role_name === 'clinician' ? '\u\u\u\u' : '\u\u\u\u'\}\line 400                  </div>\line 401                  <div><h3>$\{r.role_name.charAt(0).toUpperCase()+r.role_name.slice(1)\}</h3><p>$\{r.description\}</p></div>\line 402                </div>\line 403              </div>\line 404              <div>\line 405                <p style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--gray-500);margin-bottom:10px;">Permissions ($\{r.permissions.length\})</p>\line 406                $\{r.permissions.map(p => `\line 407                  <div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--gray-100);">\line 408                    <span style="color:var(--secondary);">\u\u\u</span>\line 409                    <div>\line 410                      <div style="font-size:13px;font-weight:600;">$\{p.permission_name.replace(/_/g,' ').replace(/\\b\\w/g,c=>c.toUpperCase())\}</div>\line 411                      <div style="font-size:11px;color:var(--gray-500);">$\{p.description\}</div>\line 412                    </div>\line 413                  </div>`).join('')\}\line 414              </div>\line 415            </div>`).join('')\}\line 416        </div>`;\line 417    \}\line 418  \line 419    loadDashboard();\line 420  </script>\line 421  </body>\line 422  </html>\line 423  \par
