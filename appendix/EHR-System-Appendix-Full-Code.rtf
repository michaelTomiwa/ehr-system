\pard\b\f0\fs25\sa220 Appendix A.2: Database Configuration\par
\pard\i\f0\fs20\sa100 File Path: backend/config/database.js\par
\pard\i\f0\fs20\sa100 Section Description: SQLite database initialization and schema creation.\par
\pard\f0\fs20\sa100 What this file does: This file defines the persistent data layer for the EHR application by connecting to SQLite and creating all required system tables.\par
\pard\f0\fs20\sa100 How this file is used in the system: It is imported by the server, middleware, seed script, and route handlers. The initializeDatabase() function is used at startup and before seeding to guarantee that the RBAC, user, clinical, appointment, and audit tables exist.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Creates the roles, permissions, role_permissions, users, patients, medical_records, appointments, and audit_logs tables.\par
\pard\f0\fs19\li360\sa70 - Uses better-sqlite3 for a lightweight embedded database suitable for a dissertation prototype.\par
\pard\f0\fs19\li360\sa70 - Enables WAL mode to improve concurrent read/write behaviour.\par
\pard\f0\fs19\li360\sa70 - Enables foreign key enforcement to preserve relational integrity across linked tables.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  const Database = require('better-sqlite3');\line   2  const path = require('path');\line   3  \line   4  const dbPath = path.join(__dirname, '..', 'ehr.db');\line   5  const db = new Database(dbPath);\line   6  \line   7  // Enable WAL mode for better performance\line   8  db.pragma('journal_mode = WAL');\line   9  db.pragma('foreign_keys = ON');\line  10  \line  11  function initializeDatabase() \{\line  12    db.exec(`\line  13      CREATE TABLE IF NOT EXISTS roles (\line  14        id INTEGER PRIMARY KEY AUTOINCREMENT,\line  15        role_name TEXT NOT NULL UNIQUE,\line  16        description TEXT,\line  17        created_at DATETIME DEFAULT CURRENT_TIMESTAMP\line  18      );\line  19  \line  20      CREATE TABLE IF NOT EXISTS permissions (\line  21        id INTEGER PRIMARY KEY AUTOINCREMENT,\line  22        permission_name TEXT NOT NULL UNIQUE,\line  23        description TEXT\line  24      );\line  25  \line  26      CREATE TABLE IF NOT EXISTS role_permissions (\line  27        role_id INTEGER NOT NULL,\line  28        permission_id INTEGER NOT NULL,\line  29        PRIMARY KEY (role_id, permission_id),\line  30        FOREIGN KEY (role_id) REFERENCES roles(id),\line  31        FOREIGN KEY (permission_id) REFERENCES permissions(id)\line  32      );\line  33  \line  34      CREATE TABLE IF NOT EXISTS users (\line  35        id INTEGER PRIMARY KEY AUTOINCREMENT,\line  36        name TEXT NOT NULL,\line  37        email TEXT NOT NULL UNIQUE,\line  38        password_hash TEXT NOT NULL,\line  39        role_id INTEGER NOT NULL,\line  40        is_active INTEGER DEFAULT 1,\line  41        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,\line  42        last_login DATETIME,\line  43        FOREIGN KEY (role_id) REFERENCES roles(id)\line  44      );\line  45  \line  46      CREATE TABLE IF NOT EXISTS patients (\line  47        id INTEGER PRIMARY KEY AUTOINCREMENT,\line  48        user_id INTEGER NOT NULL UNIQUE,\line  49        date_of_birth TEXT,\line  50        gender TEXT,\line  51        blood_group TEXT,\line  52        phone TEXT,\line  53        address TEXT,\line  54        emergency_contact TEXT,\line  55        emergency_phone TEXT,\line  56        insurance_number TEXT,\line  57        allergies TEXT,\line  58        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,\line  59        FOREIGN KEY (user_id) REFERENCES users(id)\line  60      );\line  61  \line  62      CREATE TABLE IF NOT EXISTS medical_records (\line  63        id INTEGER PRIMARY KEY AUTOINCREMENT,\line  64        patient_id INTEGER NOT NULL,\line  65        clinician_id INTEGER NOT NULL,\line  66        visit_date TEXT NOT NULL,\line  67        chief_complaint TEXT,\line  68        diagnosis TEXT,\line  69        medications TEXT,\line  70        treatment_plan TEXT,\line  71        notes TEXT,\line  72        vital_signs TEXT,\line  73        lab_results TEXT,\line  74        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,\line  75        updated_at DATETIME DEFAULT CURRENT_TIMESTAMP,\line  76        FOREIGN KEY (patient_id) REFERENCES users(id),\line  77        FOREIGN KEY (clinician_id) REFERENCES users(id)\line  78      );\line  79  \line  80      CREATE TABLE IF NOT EXISTS appointments (\line  81        id INTEGER PRIMARY KEY AUTOINCREMENT,\line  82        patient_id INTEGER NOT NULL,\line  83        clinician_id INTEGER NOT NULL,\line  84        appointment_date TEXT NOT NULL,\line  85        appointment_time TEXT NOT NULL,\line  86        reason TEXT,\line  87        status TEXT DEFAULT 'scheduled',\line  88        notes TEXT,\line  89        created_at DATETIME DEFAULT CURRENT_TIMESTAMP,\line  90        FOREIGN KEY (patient_id) REFERENCES users(id),\line  91        FOREIGN KEY (clinician_id) REFERENCES users(id)\line  92      );\line  93  \line  94      CREATE TABLE IF NOT EXISTS audit_logs (\line  95        id INTEGER PRIMARY KEY AUTOINCREMENT,\line  96        user_id INTEGER,\line  97        user_email TEXT,\line  98        user_role TEXT,\line  99        action TEXT NOT NULL,\line 100        resource TEXT,\line 101        method TEXT,\line 102        status TEXT,\line 103        details TEXT,\line 104        ip_address TEXT,\line 105        timestamp DATETIME DEFAULT CURRENT_TIMESTAMP\line 106      );\line 107    `);\line 108  \line 109    console.log('[DB] Database initialized successfully');\line 110  \}\line 111  \line 112  module.exports = \{ db, initializeDatabase \};\line 113  \par
