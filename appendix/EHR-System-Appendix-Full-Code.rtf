\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  \{\line   2    "name": "ehr-system-backend",\line   3    "version": "1.0.0",\line   4    "description": "Secure Cloud-Based EHR System with RBAC",\line   5    "main": "server.js",\line   6    "scripts": \{\line   7      "start": "node server.js",\line   8      "dev": "nodemon server.js",\line   9      "seed": "node seed.js"\line  10    \},\line  11    "dependencies": \{\line  12      "bcryptjs": "^2.4.3",\line  13      "better-sqlite3": "^9.4.3",\line  14      "cors": "^2.8.5",\line  15      "dotenv": "^16.4.5",\line  16      "express": "^4.18.3",\line  17      "jsonwebtoken": "^9.0.2",\line  18      "morgan": "^1.10.0",\line  19      "uuid": "^9.0.1"\line  20    \}\line  21  \}\line  22  \par
