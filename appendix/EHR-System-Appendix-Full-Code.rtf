\pard\b\f0\fs25\sa220 Appendix B.4: Shared Frontend Script\par
\pard\i\f0\fs20\sa100 File Path: frontend/assets/js/app.js\par
\pard\i\f0\fs20\sa100 Section Description: Common client-side helpers for API access, session state, and rendering support.\par
\pard\f0\fs20\sa100 What this file does: This file centralises common frontend logic that is reused across the HTML pages.\par
\pard\f0\fs20\sa100 How this file is used in the system: It is loaded by every frontend page. It handles API communication with the backend, token attachment, authentication checks, logout, toasts, modals, sidebar rendering, formatting utilities, and badge helpers used throughout the dashboards.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Wraps fetch requests so authenticated API calls automatically include the JWT token.\par
\pard\f0\fs19\li360\sa70 - Provides session helpers such as getUser(), getToken(), isLoggedIn(), and logout().\par
\pard\f0\fs19\li360\sa70 - Implements requireAuth() to redirect unauthorised users away from protected pages.\par
\pard\f0\fs19\li360\sa70 - Provides reusable UI helpers for toasts, modals, sidebar state, dates, and status badges.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  /* ============================================\line   2     EHR RBAC System - Core Application JS\line   3     ============================================ */\line   4  \line   5  const API_BASE = '/api';\line   6  \line   7  // ============ API HELPERS ============\line   8  async function apiRequest(method, endpoint, body = null) \{\line   9    const token = localStorage.getItem('ehr_token');\line  10    const options = \{\line  11      method: method.toUpperCase(),\line  12      headers: \{ 'Content-Type': 'application/json' \}\line  13    \};\line  14    if (token) options.headers['Authorization'] = `Bearer $\{token\}`;\line  15    if (body) options.body = JSON.stringify(body);\line  16  \line  17    try \{\line  18      const res = await fetch(`$\{API_BASE\}$\{endpoint\}`, options);\line  19      const data = await res.json();\line  20  \line  21      if (res.status === 401) \{\line  22        logout();\line  23        return null;\line  24      \}\line  25      return \{ ok: res.ok, status: res.status, data \};\line  26    \} catch (err) \{\line  27      showToast('Network error. Please check your connection.', 'error');\line  28      return null;\line  29    \}\line  30  \}\line  31  \line  32  const api = \{\line  33    get: (ep) => apiRequest('GET', ep),\line  34    post: (ep, body) => apiRequest('POST', ep, body),\line  35    put: (ep, body) => apiRequest('PUT', ep, body),\line  36    delete: (ep) => apiRequest('DELETE', ep),\line  37  \};\line  38  \line  39  // ============ AUTH ============\line  40  function getUser() \{\line  41    const u = localStorage.getItem('ehr_user');\line  42    return u ? JSON.parse(u) : null;\line  43  \}\line  44  function getToken() \{ return localStorage.getItem('ehr_token'); \}\line  45  function isLoggedIn() \{ return !!getToken() && !!getUser(); \}\line  46  \line  47  function logout() \{\line  48    api.post('/auth/logout').catch(() => \{\});\line  49    localStorage.removeItem('ehr_token');\line  50    localStorage.removeItem('ehr_user');\line  51    window.location.href = '/';\line  52  \}\line  53  \line  54  // Guard \u\u\u redirect if not authenticated\line  55  function requireAuth(allowedRoles = []) \{\line  56    if (!isLoggedIn()) \{ window.location.href = '/'; return false; \}\line  57    const user = getUser();\line  58    if (allowedRoles.length && !allowedRoles.includes(user.role)) \{\line  59      window.location.href = '/access-denied.html';\line  60      return false;\line  61    \}\line  62    return true;\line  63  \}\line  64  \line  65  // ============ TOAST ============\line  66  function showToast(message, type = 'info', duration = 3500) \{\line  67    let container = document.querySelector('.toast-container');\line  68    if (!container) \{\line  69      container = document.createElement('div');\line  70      container.className = 'toast-container';\line  71      document.body.appendChild(container);\line  72    \}\line  73    const icons = \{ success: '\u\u\u', error: '\u\u\u', warning: '\u\u\u\u\u\u', info: '\u\u\u\u\u\u' \};\line  74    const toast = document.createElement('div');\line  75    toast.className = `toast $\{type\}`;\line  76    toast.innerHTML = `<span>$\{icons[type] || ''\}</span><span>$\{message\}</span>`;\line  77    container.appendChild(toast);\line  78    setTimeout(() => \{ toast.style.opacity = '0'; toast.style.transform = 'translateX(20px)'; toast.style.transition = '0.3s'; setTimeout(() => toast.remove(), 300); \}, duration);\line  79  \}\line  80  \line  81  // ============ MODAL ============\line  82  function openModal(id) \{ document.getElementById(id).style.display = 'flex'; \}\line  83  function closeModal(id) \{ document.getElementById(id).style.display = 'none'; \}\line  84  function createModal(id, title, bodyHtml, footerHtml = '') \{\line  85    let m = document.getElementById(id);\line  86    if (!m) \{ m = document.createElement('div'); m.id = id; m.className = 'modal-overlay'; document.body.appendChild(m); \}\line  87    m.innerHTML = `<div class="modal">\line  88      <div class="modal-header">\line  89        <h3>$\{title\}</h3>\line  90        <button class="modal-close" onclick="closeModal('$\{id\}')">\u\u\u</button>\line  91      </div>\line  92      <div class="modal-body">$\{bodyHtml\}</div>\line  93      $\{footerHtml ? `<div class="modal-footer">$\{footerHtml\}</div>` : ''\}\line  94    </div>`;\line  95    m.style.display = 'flex';\line  96    m.addEventListener('click', (e) => \{ if (e.target === m) closeModal(id); \});\line  97  \}\line  98  \line  99  // ============ SIDEBAR ============\line 100  function initSidebar(activeItem) \{\line 101    const user = getUser();\line 102    if (!user) return;\line 103  \line 104    const avatarColors = \{ admin: '#7c3aed', clinician: '#1e40af', patient: '#065f46' \};\line 105    const avatarColor = avatarColors[user.role] || '#374151';\line 106    const initials = user.name.split(' ').map(n => n[0]).join('').substring(0,2).toUpperCase();\line 107  \line 108    document.querySelectorAll('.user-avatar').forEach(el => \{\line 109      el.style.background = avatarColor;\line 110      el.textContent = initials;\line 111    \});\line 112    document.querySelectorAll('.sidebar-user-name').forEach(el => el.textContent = user.name);\line 113    document.querySelectorAll('.sidebar-user-role').forEach(el => el.textContent = user.role.charAt(0).toUpperCase() + user.role.slice(1));\line 114    document.querySelectorAll('.topbar-user-name').forEach(el => el.textContent = user.name);\line 115  \line 116    document.querySelectorAll('.nav-item').forEach(el => \{\line 117      el.classList.toggle('active', el.dataset.page === activeItem);\line 118    \});\line 119  \}\line 120  \line 121  // ============ DATE UTILS ============\line 122  function formatDate(dateStr) \{\line 123    if (!dateStr) return '\u\u\u';\line 124    const d = new Date(dateStr);\line 125    return d.toLocaleDateString('en-GB', \{ day: '2-digit', month: 'short', year: 'numeric' \});\line 126  \}\line 127  function formatDateTime(dateStr) \{\line 128    if (!dateStr) return '\u\u\u';\line 129    return new Date(dateStr).toLocaleString('en-GB', \{ day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' \});\line 130  \}\line 131  \line 132  // ============ BADGE HELPERS ============\line 133  function roleBadge(role) \{\line 134    const labels = \{ admin: 'Admin', clinician: 'Clinician', patient: 'Patient' \};\line 135    return `<span class="badge badge-$\{role\}">$\{labels[role] || role\}</span>`;\line 136  \}\line 137  function statusBadge(status) \{\line 138    const map = \{\line 139      GRANTED: 'badge-success', DENIED: 'badge-danger',\line 140      scheduled: 'badge-info', completed: 'badge-success', cancelled: 'badge-gray',\line 141      '1': 'badge-success', '0': 'badge-danger',\line 142    \};\line 143    return `<span class="badge $\{map[status] || 'badge-gray'\}">$\{status\}</span>`;\line 144  \}\line 145  \line 146  // ============ EMPTY STATE ============\line 147  function emptyState(icon, title, text) \{\line 148    return `<div class="empty-state"><div class="icon">$\{icon\}</div><h3>$\{title\}</h3><p>$\{text\}</p></div>`;\line 149  \}\line 150  \line 151  // ============ PAGE LOADER ============\line 152  function showPageLoader(containerId) \{\line 153    document.getElementById(containerId).innerHTML = `<div class="page-loader"><div class="spinner"></div><p>Loading...</p></div>`;\line 154  \}\line 155  \par
