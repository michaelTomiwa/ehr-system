  1  const express = require('express');\line   2  const router = express.Router();\line   3  const \{ db \} = require('../config/database');\line   4  const \{ authenticateToken, requireRole, logAudit \} = require('../middleware/auth');\line   5  \line   6  router.use(authenticateToken, requireRole('clinician', 'admin'));\line   7  \line   8  // GET /api/clinician/dashboard\line   9  router.get('/dashboard', (req, res) => \{\line  10    logAudit(req, req.user, 'VIEW_CLINICIAN_DASHBOARD', 'GRANTED');\line  11    const stats = \{\line  12      my_patients: db.prepare(`\line  13        SELECT COUNT(DISTINCT patient_id) as c FROM medical_records WHERE clinician_id = ?\line  14      `).get(req.user.id).c,\line  15      my_appointments: db.prepare(`\line  16        SELECT COUNT(*) as c FROM appointments WHERE clinician_id = ? AND status = 'scheduled'\line  17      `).get(req.user.id).c,\line  18      records_created: db.prepare(`\line  19        SELECT COUNT(*) as c FROM medical_records WHERE clinician_id = ?\line  20      `).get(req.user.id).c,\line  21      recent_patients: db.prepare(`\line  22        SELECT DISTINCT u.id, u.name, u.email, mr.visit_date, mr.diagnosis\line  23        FROM users u\line  24        JOIN medical_records mr ON mr.patient_id = u.id\line  25        WHERE mr.clinician_id = ?\line  26        ORDER BY mr.created_at DESC LIMIT 5\line  27      `).all(req.user.id),\line  28      upcoming_appointments: db.prepare(`\line  29        SELECT a.*, p.name as patient_name, p.email as patient_email\line  30        FROM appointments a JOIN users p ON a.patient_id = p.id\line  31        WHERE a.clinician_id = ? AND a.status = 'scheduled'\line  32        ORDER BY a.appointment_date, a.appointment_time LIMIT 5\line  33      `).all(req.user.id)\line  34    \};\line  35    res.json(\{ success: true, data: stats \});\line  36  \});\line  37  \line  38  // GET /api/clinician/patients - List all patients\line  39  router.get('/patients', (req, res) => \{\line  40    logAudit(req, req.user, 'VIEW_PATIENTS_LIST', 'GRANTED');\line  41    const patients = db.prepare(`\line  42      SELECT u.id, u.name, u.email, u.created_at,\line  43        pt.date_of_birth, pt.gender, pt.blood_group, pt.phone, pt.allergies\line  44      FROM users u\line  45      JOIN roles r ON u.role_id = r.id\line  46      LEFT JOIN patients pt ON pt.user_id = u.id\line  47      WHERE r.role_name = 'patient' AND u.is_active = 1\line  48      ORDER BY u.name\line  49    `).all();\line  50    res.json(\{ success: true, data: patients \});\line  51  \});\line  52  \line  53  // GET /api/clinician/patients/:id - View patient detail\line  54  router.get('/patients/:id', (req, res) => \{\line  55    const patientId = req.params.id;\line  56    logAudit(req, req.user, 'VIEW_PATIENT_DETAIL', 'GRANTED', `Patient ID: $\{patientId\}`);\line  57  \line  58    const patient = db.prepare(`\line  59      SELECT u.id, u.name, u.email, u.created_at,\line  60        pt.date_of_birth, pt.gender, pt.blood_group, pt.phone, pt.address,\line  61        pt.emergency_contact, pt.emergency_phone, pt.insurance_number, pt.allergies\line  62      FROM users u\line  63      JOIN roles r ON u.role_id = r.id\line  64      LEFT JOIN patients pt ON pt.user_id = u.id\line  65      WHERE u.id = ? AND r.role_name = 'patient'\line  66    `).get(patientId);\line  67  \line  68    if (!patient) return res.status(404).json(\{ success: false, message: 'Patient not found.' \});\line  69  \line  70    const records = db.prepare(`\line  71      SELECT mr.*, c.name as clinician_name\line  72      FROM medical_records mr\line  73      JOIN users c ON mr.clinician_id = c.id\line  74      WHERE mr.patient_id = ?\line  75      ORDER BY mr.visit_date DESC\line  76    `).all(patientId);\line  77  \line  78    const appointments = db.prepare(`\line  79      SELECT a.*, c.name as clinician_name\line  80      FROM appointments a\line  81      JOIN users c ON a.clinician_id = c.id\line  82      WHERE a.patient_id = ?\line  83      ORDER BY a.appointment_date DESC\line  84    `).all(patientId);\line  85  \line  86    res.json(\{ success: true, data: \{ patient, records, appointments \} \});\line  87  \});\line  88  \line  89  // GET /api/clinician/records - Get all records created by this clinician\line  90  router.get('/records', (req, res) => \{\line  91    logAudit(req, req.user, 'VIEW_OWN_RECORDS_LIST', 'GRANTED');\line  92    const records = db.prepare(`\line  93      SELECT mr.*, p.name as patient_name, p.email as patient_email\line  94      FROM medical_records mr\line  95      JOIN users p ON mr.patient_id = p.id\line  96      WHERE mr.clinician_id = ?\line  97      ORDER BY mr.created_at DESC\line  98    `).all(req.user.id);\line  99    res.json(\{ success: true, data: records \});\line 100  \});\line 101  \line 102  // POST /api/clinician/records - Create medical record\line 103  router.post('/records', (req, res) => \{\line 104    const \{ patient_id, visit_date, chief_complaint, diagnosis, medications, treatment_plan, notes, vital_signs, lab_results \} = req.body;\line 105  \line 106    if (!patient_id || !visit_date || !diagnosis) \{\line 107      return res.status(400).json(\{ success: false, message: 'patient_id, visit_date and diagnosis are required.' \});\line 108    \}\line 109  \line 110    // Verify patient exists\line 111    const patient = db.prepare("SELECT u.id FROM users u JOIN roles r ON u.role_id=r.id WHERE u.id=? AND r.role_name='patient'").get(patient_id);\line 112    if (!patient) return res.status(404).json(\{ success: false, message: 'Patient not found.' \});\line 113  \line 114    const result = db.prepare(`\line 115      INSERT INTO medical_records (patient_id, clinician_id, visit_date, chief_complaint, diagnosis, medications, treatment_plan, notes, vital_signs, lab_results)\line 116      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\line 117    `).run(patient_id, req.user.id, visit_date, chief_complaint, diagnosis, medications, treatment_plan, notes, vital_signs, lab_results);\line 118  \line 119    logAudit(req, req.user, 'CREATE_MEDICAL_RECORD', 'GRANTED', `Record ID: $\{result.lastInsertRowid\} for Patient: $\{patient_id\}`);\line 120    res.status(201).json(\{ success: true, message: 'Medical record created.', recordId: result.lastInsertRowid \});\line 121  \});\line 122  \line 123  // PUT /api/clinician/records/:id - Update medical record\line 124  router.put('/records/:id', (req, res) => \{\line 125    const recordId = req.params.id;\line 126    const record = db.prepare('SELECT * FROM medical_records WHERE id = ?').get(recordId);\line 127    if (!record) return res.status(404).json(\{ success: false, message: 'Record not found.' \});\line 128    if (record.clinician_id !== req.user.id && req.user.role !== 'admin') \{\line 129      logAudit(req, req.user, 'UPDATE_RECORD_DENIED', 'DENIED', `Record $\{recordId\} belongs to another clinician`);\line 130      return res.status(403).json(\{ success: false, message: 'You can only update your own records.' \});\line 131    \}\line 132  \line 133    const \{ chief_complaint, diagnosis, medications, treatment_plan, notes, vital_signs, lab_results \} = req.body;\line 134    db.prepare(`\line 135      UPDATE medical_records SET chief_complaint=?, diagnosis=?, medications=?, treatment_plan=?, notes=?, vital_signs=?, lab_results=?, updated_at=CURRENT_TIMESTAMP WHERE id=?\line 136    `).run(chief_complaint || record.chief_complaint, diagnosis || record.diagnosis, medications || record.medications,\line 137       treatment_plan || record.treatment_plan, notes || record.notes, vital_signs || record.vital_signs, lab_results || record.lab_results, recordId);\line 138  \line 139    logAudit(req, req.user, 'UPDATE_MEDICAL_RECORD', 'GRANTED', `Record ID: $\{recordId\}`);\line 140    res.json(\{ success: true, message: 'Record updated successfully.' \});\line 141  \});\line 142  \line 143  // GET /api/clinician/appointments\line 144  router.get('/appointments', (req, res) => \{\line 145    logAudit(req, req.user, 'VIEW_APPOINTMENTS', 'GRANTED');\line 146    const appointments = db.prepare(`\line 147      SELECT a.*, p.name as patient_name, p.email as patient_email\line 148      FROM appointments a\line 149      JOIN users p ON a.patient_id = p.id\line 150      WHERE a.clinician_id = ?\line 151      ORDER BY a.appointment_date DESC\line 152    `).all(req.user.id);\line 153    res.json(\{ success: true, data: appointments \});\line 154  \});\line 155  \line 156  // POST /api/clinician/appointments - Create appointment\line 157  router.post('/appointments', (req, res) => \{\line 158    const \{ patient_id, appointment_date, appointment_time, reason, notes \} = req.body;\line 159    if (!patient_id || !appointment_date || !appointment_time) \{\line 160      return res.status(400).json(\{ success: false, message: 'patient_id, date and time required.' \});\line 161    \}\line 162  \line 163    const result = db.prepare(`\line 164      INSERT INTO appointments (patient_id, clinician_id, appointment_date, appointment_time, reason, notes)\line 165      VALUES (?, ?, ?, ?, ?, ?)\line 166    `).run(patient_id, req.user.id, appointment_date, appointment_time, reason, notes);\line 167  \line 168    logAudit(req, req.user, 'CREATE_APPOINTMENT', 'GRANTED', `Appointment for Patient: $\{patient_id\} on $\{appointment_date\}`);\line 169    res.status(201).json(\{ success: true, message: 'Appointment scheduled.', appointmentId: result.lastInsertRowid \});\line 170  \});\line 171  \line 172  // PUT /api/clinician/appointments/:id/status\line 173  router.put('/appointments/:id/status', (req, res) => \{\line 174    const \{ status \} = req.body;\line 175    if (!['scheduled', 'completed', 'cancelled'].includes(status)) \{\line 176      return res.status(400).json(\{ success: false, message: 'Invalid status.' \});\line 177    \}\line 178    db.prepare('UPDATE appointments SET status = ? WHERE id = ? AND clinician_id = ?').run(status, req.params.id, req.user.id);\line 179    logAudit(req, req.user, 'UPDATE_APPOINTMENT_STATUS', 'GRANTED', `Appointment $\{req.params.id\} -> $\{status\}`);\line 180    res.json(\{ success: true, message: 'Appointment status updated.' \});\line 181  \});\line 182  \line 183  module.exports = router;\line 184  \par
