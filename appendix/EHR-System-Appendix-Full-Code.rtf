\pard\b\f0\fs25\sa220 Appendix A.4: Authentication and RBAC Middleware\par
\pard\i\f0\fs20\sa100 File Path: backend/middleware/auth.js\par
\pard\i\f0\fs20\sa100 Section Description: JWT verification, user resolution, and role-based access control helpers.\par
\pard\f0\fs20\sa100 What this file does: This file contains the core security controls that protect backend resources through authentication, authorization, and auditing.\par
\pard\f0\fs20\sa100 How this file is used in the system: It is imported by the route modules. authenticateToken validates bearer tokens, requireRole checks the user role before access is granted, generateToken issues session tokens during login, and logAudit records both successful and denied access attempts.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Validates JWT tokens and rejects missing, invalid, or expired credentials.\par
\pard\f0\fs19\li360\sa70 - Loads the authenticated user from the database and attaches the user object to the request.\par
\pard\f0\fs19\li360\sa70 - Enforces role-based access control for protected route groups.\par
\pard\f0\fs19\li360\sa70 - Writes audit trail entries for denied access, invalid tokens, and authenticated actions.\par
\pard\f0\fs19\li360\sa70 - Generates 8-hour JWT session tokens for logged-in users.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  const jwt = require('jsonwebtoken');\line   2  const \{ db \} = require('../config/database');\line   3  \line   4  const JWT_SECRET = process.env.JWT_SECRET || 'EHR_SECURE_JWT_SECRET_2026_RBAC';\line   5  \line   6  function authenticateToken(req, res, next) \{\line   7    const authHeader = req.headers['authorization'];\line   8    const token = authHeader && authHeader.split(' ')[1];\line   9  \line  10    if (!token) \{\line  11      logAudit(req, null, 'UNAUTHORIZED', 'DENIED', 'No token provided');\line  12      return res.status(401).json(\{ success: false, message: 'Access denied. Authentication required.' \});\line  13    \}\line  14  \line  15    try \{\line  16      const decoded = jwt.verify(token, JWT_SECRET);\line  17      const user = db.prepare('SELECT u.*, r.role_name FROM users u JOIN roles r ON u.role_id = r.id WHERE u.id = ? AND u.is_active = 1').get(decoded.userId);\line  18      if (!user) \{\line  19        return res.status(401).json(\{ success: false, message: 'Invalid token. User not found.' \});\line  20      \}\line  21      req.user = \{ id: user.id, name: user.name, email: user.email, role: user.role_name \};\line  22      next();\line  23    \} catch (err) \{\line  24      logAudit(req, null, 'INVALID_TOKEN', 'DENIED', err.message);\line  25      return res.status(403).json(\{ success: false, message: 'Invalid or expired token.' \});\line  26    \}\line  27  \}\line  28  \line  29  function requireRole(...roles) \{\line  30    return (req, res, next) => \{\line  31      if (!req.user) \{\line  32        return res.status(401).json(\{ success: false, message: 'Authentication required.' \});\line  33      \}\line  34      if (!roles.includes(req.user.role)) \{\line  35        logAudit(req, req.user, 'ACCESS_DENIED', 'DENIED', `Role $\{req.user.role\} not in [$\{roles.join(',')\}]`);\line  36        return res.status(403).json(\{\line  37          success: false,\line  38          message: `Access denied. Required role: $\{roles.join(' or ')\}. Your role: $\{req.user.role\}`\line  39        \});\line  40      \}\line  41      next();\line  42    \};\line  43  \}\line  44  \line  45  function requirePermission(permission) \{\line  46    return (req, res, next) => \{\line  47      if (!req.user) \{\line  48        return res.status(401).json(\{ success: false, message: 'Authentication required.' \});\line  49      \}\line  50      const hasPermission = db.prepare(`\line  51        SELECT rp.* FROM role_permissions rp\line  52        JOIN roles r ON rp.role_id = r.id\line  53        JOIN permissions p ON rp.permission_id = p.id\line  54        WHERE r.role_name = ? AND p.permission_name = ?\line  55      `).get(req.user.role, permission);\line  56  \line  57      if (!hasPermission) \{\line  58        logAudit(req, req.user, 'PERMISSION_DENIED', 'DENIED', `Missing permission: $\{permission\}`);\line  59        return res.status(403).json(\{\line  60          success: false,\line  61          message: `Access denied. You do not have '$\{permission\}' permission.`\line  62        \});\line  63      \}\line  64      next();\line  65    \};\line  66  \}\line  67  \line  68  function logAudit(req, user, action, status, details = '') \{\line  69    try \{\line  70      db.prepare(`\line  71        INSERT INTO audit_logs (user_id, user_email, user_role, action, resource, method, status, details, ip_address)\line  72        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\line  73      `).run(\line  74        user?.id || null,\line  75        user?.email || req.headers['x-user-email'] || null,\line  76        user?.role || null,\line  77        action,\line  78        req.originalUrl || req.url,\line  79        req.method,\line  80        status,\line  81        details,\line  82        req.ip || req.connection?.remoteAddress || 'unknown'\line  83      );\line  84    \} catch (e) \{ /* silent fail for audit */ \}\line  85  \}\line  86  \line  87  function generateToken(userId, role) \{\line  88    return jwt.sign(\{ userId, role \}, JWT_SECRET, \{ expiresIn: '8h' \});\line  89  \}\line  90  \line  91  module.exports = \{ authenticateToken, requireRole, requirePermission, logAudit, generateToken \};\line  92  \par
