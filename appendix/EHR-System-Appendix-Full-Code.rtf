\pard\b\f0\fs25\sa220 Appendix A.3: Database Seeding Script\par
\pard\i\f0\fs20\sa100 File Path: backend/config/seed.js\par
\pard\i\f0\fs20\sa100 Section Description: Synthetic data creation for roles, users, appointments, and medical records.\par
\pard\f0\fs20\sa100 What this file does: This file populates the database with demonstration data required to test and present the RBAC-based EHR system.\par
\pard\f0\fs20\sa100 How this file is used in the system: It is run during project setup to create the default roles, permissions, demo user accounts, patient profiles, medical records, appointments, and sample audit logs used for dissertation screenshots, evaluation, and system demonstrations.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Creates the three role categories: admin, clinician, and patient.\par
\pard\f0\fs19\li360\sa70 - Maps each role to the permissions that enforce the RBAC model.\par
\pard\f0\fs19\li360\sa70 - Hashes the shared demo password using bcrypt before storing users.\par
\pard\f0\fs19\li360\sa70 - Creates synthetic Nigerian-style patient profiles, appointments, and consultation records.\par
\pard\f0\fs19\li360\sa70 - Seeds audit logs so the security and accountability features can be demonstrated immediately.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  const bcrypt = require('bcryptjs');\line   2  const \{ db, initializeDatabase \} = require('./database');\line   3  \line   4  function seedDatabase() \{\line   5    initializeDatabase();\line   6  \line   7    // Insert Roles\line   8    const insertRole = db.prepare('INSERT OR IGNORE INTO roles (role_name, description) VALUES (?, ?)');\line   9    insertRole.run('admin', 'System administrator with full access');\line  10    insertRole.run('clinician', 'Healthcare professional with patient record access');\line  11    insertRole.run('patient', 'Patient with access to own health records');\line  12  \line  13    // Insert Permissions\line  14    const insertPerm = db.prepare('INSERT OR IGNORE INTO permissions (permission_name, description) VALUES (?, ?)');\line  15    const perms = [\line  16      ['manage_users', 'Create, update, delete users'],\line  17      ['view_audit_logs', 'Access system audit logs'],\line  18      ['view_all_records', 'View all patient records'],\line  19      ['system_dashboard', 'Access system statistics dashboard'],\line  20      ['view_patient_records', 'View patient medical records'],\line  21      ['create_medical_record', 'Create new medical records'],\line  22      ['update_medical_record', 'Update existing medical records'],\line  23      ['manage_appointments', 'Create and manage appointments'],\line  24      ['view_own_records', 'View own health records'],\line  25      ['view_own_appointments', 'View own appointments'],\line  26      ['view_own_profile', 'View own patient profile'],\line  27    ];\line  28    perms.forEach(([name, desc]) => insertPerm.run(name, desc));\line  29  \line  30    // Map role IDs\line  31    const adminRole = db.prepare('SELECT id FROM roles WHERE role_name = ?').get('admin');\line  32    const clinicianRole = db.prepare('SELECT id FROM roles WHERE role_name = ?').get('clinician');\line  33    const patientRole = db.prepare('SELECT id FROM roles WHERE role_name = ?').get('patient');\line  34  \line  35    // Map permission IDs\line  36    const getPermId = (name) => db.prepare('SELECT id FROM permissions WHERE permission_name = ?').get(name).id;\line  37  \line  38    // Role-Permission assignments\line  39    const insertRP = db.prepare('INSERT OR IGNORE INTO role_permissions (role_id, permission_id) VALUES (?, ?)');\line  40  \line  41    // Admin gets all\line  42    perms.forEach(([name]) => insertRP.run(adminRole.id, getPermId(name)));\line  43  \line  44    // Clinician permissions\line  45    ['view_patient_records', 'create_medical_record', 'update_medical_record', 'manage_appointments', 'view_own_profile'].forEach(p =>\line  46      insertRP.run(clinicianRole.id, getPermId(p))\line  47    );\line  48  \line  49    // Patient permissions\line  50    ['view_own_records', 'view_own_appointments', 'view_own_profile'].forEach(p =>\line  51      insertRP.run(patientRole.id, getPermId(p))\line  52    );\line  53  \line  54    // Insert Users\line  55    const hash = bcrypt.hashSync('Password123!', 10);\line  56    const insertUser = db.prepare('INSERT OR IGNORE INTO users (name, email, password_hash, role_id) VALUES (?, ?, ?, ?)');\line  57  \line  58    // Admin\line  59    insertUser.run('System Administrator', 'admin@ehrsystem.com', hash, adminRole.id);\line  60  \line  61    // Clinicians\line  62    insertUser.run('Dr. Amina Okafor', 'amina.okafor@ehrsystem.com', hash, clinicianRole.id);\line  63    insertUser.run('Dr. James Adeyemi', 'james.adeyemi@ehrsystem.com', hash, clinicianRole.id);\line  64    insertUser.run('Nurse Fatima Bello', 'fatima.bello@ehrsystem.com', hash, clinicianRole.id);\line  65  \line  66    // Patients\line  67    const patientData = [\line  68      ['Emeka Chukwu', 'emeka.chukwu@gmail.com', '1985-03-14', 'Male', 'O+', '+234-802-111-0001'],\line  69      ['Ngozi Obi', 'ngozi.obi@gmail.com', '1990-07-22', 'Female', 'A+', '+234-803-222-0002'],\line  70      ['Tunde Afolabi', 'tunde.afolabi@gmail.com', '1978-11-05', 'Male', 'B-', 