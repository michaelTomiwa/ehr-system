\pard\b\f0\fs25\sa220 Appendix B.6: Clinician Dashboard\par
\pard\i\f0\fs20\sa100 File Path: frontend/pages/clinician/dashboard.html\par
\pard\i\f0\fs20\sa100 Section Description: Clinician frontend for records, patients, and appointments.\par
\pard\f0\fs20\sa100 What this file does: This file defines the clinician-facing user interface for day-to-day healthcare operations.\par
\pard\f0\fs20\sa100 How this file is used in the system: After clinician login, the page loads clinician dashboard statistics, patient registry data, individual patient detail views, record creation forms, and appointment scheduling tools by calling the clinician API endpoints.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Displays a clinician dashboard with workload and activity summaries.\par
\pard\f0\fs19\li360\sa70 - Shows a searchable patient registry and full patient-detail view.\par
\pard\f0\fs19\li360\sa70 - Allows creation of new medical records through a modal form.\par
\pard\f0\fs19\li360\sa70 - Allows appointment scheduling and appointment status updates.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  <!DOCTYPE html>\line   2  <html lang="en">\line   3  <head>\line   4    <meta charset="UTF-8">\line   5    <meta name="viewport" content="width=device-width, initial-scale=1.0">\line   6    <title>Clinician Dashboard \u\u\u SecureEHR</title>\line   7    <link rel="stylesheet" href="/assets/css/style.css">\line   8    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">\line   9  </head>\line  10  <body>\line  11  <div class="dashboard-layout">\line  12  \line  13    <aside class="sidebar">\line  14      <div class="sidebar-header">\line  15        <div class="sidebar-logo">\line  16          <div class="logo-icon">\u\u\u\u</div>\line  17          <div class="sidebar-logo-text"><h2>SecureEHR</h2><p>Clinician Panel</p></div>\line  18        </div>\line  19      </div>\line  20      <div class="sidebar-user">\line  21        <div class="user-avatar"></div>\line  22        <div class="sidebar-user-info">\line  23          <div class="name sidebar-user-name"></div>\line  24          <div class="role sidebar-user-role"></div>\line  25        </div>\line  26      </div>\line  27      <nav class="sidebar-nav">\line  28        <div class="nav-section-title">Main</div>\line  29        <div class="nav-item active" data-page="dashboard" onclick="showSection('dashboard')"><span class="icon">\u\u\u\u</span> Dashboard</div>\line  30        <div class="nav-section-title">Clinical</div>\line  31        <div class="nav-item" data-page="patients" onclick="showSection('patients')"><span class="icon">\u\u\u\u</span> Patients</div>\line  32        <div class="nav-item" data-page="records" onclick="showSection('records')"><span class="icon">\u\u\u\u</span> Medical Records</div>\line  33        <div class="nav-item" data-page="appointments" onclick="showSection('appointments')"><span class="icon">\u\u\u\u</span> Appointments</div>\line  34      </nav>\line  35      <div class="sidebar-footer">\line  36        <button class="logout-btn" onclick="logout()"><span>\u\u\u\u</span> Sign Out</button>\line  37      </div>\line  38    </aside>\line  39  \line  40    <main class="main-content">\line  41      <div class="topbar">\line  42        <div class="topbar-title"><h1 id="section-title">Dashboard</h1><p id="section-subtitle">Your clinical overview</p></div>\line  43        <div style="display:flex; align-items:center; gap:12px;">\line  44          <span class="badge badge-clinician">Clinician</span>\line  45          <span class="topbar-user-name" style="font-weight:600; font-size:13px;"></span>\line  46        </div>\line  47      </div>\line  48  \line  49      <div class="page-content">\line  50  \line  51        <!-- DASHBOARD -->\line  52        <section id="sec-dashboard">\line  53          <div class="stats-grid" id="clin-stats"></div>\line  54          <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">\line  55            <div class="card">\line  56              <div class="card-header"><div><h3>Recent Patients</h3><p>Patients you recently attended</p></div></div>\line  57              <div id="recent-patients"></div>\line  58            </div>\line  59            <div class="card">\line  60              <div class="card-header"><div><h3>Upcoming Appointments</h3></div><button class="btn btn-primary btn-sm" onclick="showSection('appointments')">View All</button></div>\line  61              <div id="upcoming-appts"></div>\line  62            </div>\line  63          </div>\line  64        </section>\line  65  \line  66        <!-- PATIENTS -->\line  67        <section id="sec-patients" style="display:none;">\line  68          <div class="card">\line  69            <div class="card-header"><div><h3>Patient Registry</h3><p>All registered patients</p></div></div>\line  70            <div class="search-bar">\line  71              <input type="text" id="patient-search" placeholder="Search by name or email..." oninput="filterPatients()">\line  72            </div>\line  73            <div class="table-container">\line  74              <table>\line  75                <thead><tr><th>Name</th><th>Email</th><th>DOB</th><th>Gender</th><th>Blood Group</th><th>Phone</th><th>Allergies</th><th>Action</th></tr></thead>\line  76                <tbody id="patients-table-body"></tbody>\line  77              </table>\line  78            </div>\line  79          </div>\line  80        </section>\line  81  \line  82        <!-- RECORDS -->\line  83        <section id="sec-records" style="display:none;">\line  84          <div class="card">\line  85            <div class="card-header">\line  86              <div><h3>Medical Records</h3><p>Records you have created</p></div>\line  87              <button class="btn btn-primary btn-sm" onclick="openNewRecordModal()">+ New Record</button>\line  88            </div>\line  89            <div id="records-list"></div>\line  90          </div>\line  91        </section>\line  92  \line  93        <!-- APPOINTMENTS -->\line  94        <section id="sec-appointments" style="display:none;">\line  95          <div class="card">\line  96            <div class="card-header">\line  97              <div><h3>Appointments</h3><p>Your scheduled and completed appointments</p></div>\line  98              <button class="btn btn-primary btn-sm" onclick="openApptModal()">+ New Appointment</button>\line  99            </div>\line 100            <div class="table-container">\line 101              <table>\line 102                <thead><tr><th>Patient</th><th>Date</th><th>Time</th><th>Reason</th><th>Status</th><th>Action</th></tr></thead>\line 103                <tbody id="appts-table-body"></tbody>\line 104              </table>\line 105            </div>\line 106          </div>\line 107        </section>\line 108  \line 109        <!-- PATIENT DETAIL -->\line 110        <section id="sec-patient-detail" style="display:none;">\line 111          <div style="margin-bottom:16px;">\line 112            <button class="btn btn-secondary btn-sm" onclick="showSection('patients')">\u\u\u Back to Patients</button>\line 113          </div>\line 114          <div id="patient-detail-content"></div>\line 115        </section>\line 116  \line 117      </div>\line 118    </main>\line 119  </div>\line 120  \line 121  <!-- New Medical Record Modal -->\line 122  <div id="record-modal" class="modal-overlay" style="display:none;">\line 123    <div class="modal" style="max-width:680px;">\line 124      <div class="modal-header"><h3>New Medical Record</h3><button class="modal-close" onclick="closeModal('record-modal')">\u\u\u</button></div>\line 125      <div class="modal-body">\line 126        <div id="record-form-alert" style="display:none;"></div>\line 127        <div class="form-grid">\line 128          <div class="form-group form-full">\line 129            <label>Patient</label>\line 130            <select id="r-patient"><option value="">Select patient...</option></select>\line 131          </div>\line 132          <div class="form-group"><label>Visit Date</label><input type="date" id="r-date"></div>\line 133          <div class="form-group"><label>Chief Complaint</label><input type="text" id="r-complaint" placeholder="Presenting complaint"></div>\line 134          <div class="form-group form-full"><label>Diagnosis</label><textarea id="r-diagnosis" rows="2" placeholder="Clinical diagnosis"></textarea></div>\line 135          <div class="form-group form-full"><label>Vital Signs</label><input type="text" id="r-vitals" placeholder="e.g. BP: 120/80, Temp: 37\u\uC, HR: 72bpm, SpO2: 99%"></div>\line 136          <div class="form-group form-full"><label>Medications Prescribed</label><textarea id="r-medications" rows="2" placeholder="Medications, dosage, and frequency"></textarea></div>\line 137          <div class="form-group form-full"><label>Treatment Plan</label><textarea id="r-treatment" rows="2" placeholder="Management and treatment plan"></textarea></div>\line 138          <div class="form-group form-full"><label>Lab Results</label><textarea id="r-labs" rows="2" placeholder="Laboratory and investigation results"></textarea></div>\line 139          <div class="form-group form-full"><label>Clinical Notes</label><textarea id="r-notes" rows="2" placeholder="Additional notes"></textarea></div>\line 140        </div>\line 141      </div>\line 142      <div class="modal-footer">\line 143        <button class="btn btn-secondary" onclick="closeModal('record-modal')">Cancel</button>\line 144        <button class="btn btn-primary" onclick="saveRecord()">Save Record</button>\line 145      </div>\line 146    </div>\line 147  </div>\line 148  \line 149  <!-- New Appointment Modal -->\line 150  <div id="appt-modal" class="modal-overlay" style="display:none;">\line 151    <div class="modal">\line 152      <div class="modal-header"><h3>Schedule Appointment</h3><button class="modal-close" onclick="closeModal('appt-modal')">\u\u\u</button></div>\line 153      <div class="modal-body">\line 154        <div id="appt-form-alert" style="display:none;"></div>\line 155        <div class="form-grid">\line 156          <div class="form-group form-full"><label>Patient</label><select id="a-patient"><option value="">Select patient...</option></select></div>\line 157          <div class="form-group"><label>Date</label><input type="date" id="a-date"></div>\line 158          <div class="form-group"><label>Time</label><input type="time" id="a-time"></div>\line 159          <div class="form-group form-full"><label>Reason</label><input type="text" id="a-reason" placeholder="Reason for appointment"></div>\line 160          <div class="form-group form-full"><label>Notes</label><textarea id="a-notes" rows="2" placeholder="Additional notes"></textarea></div>\line 161        </div>\line 162      </div>\line 163      <div class="modal-footer">\line 164        <button class="btn btn-secondary" onclick="closeModal('appt-modal')">Cancel</button>\line 165        <button class="btn btn-primary" onclick="saveAppt()">Schedule</button>\line 166      </div>\line 167    </div>\line 168  </div>\line 169  \line 170  <script src="/assets/js/app.js"></script>\line 171  <script>\line 172    let allPatients = [];\line 173    if (!requireAuth(['clinician'])) throw new Error('auth');\line 174    initSidebar('dashboard');\line 175  \line 176    function showSection(name) \{\line 177      ['dashboard','patients','records','appointments','patient-detail'].forEach(s => \{\line 178        document.getElementById(`sec-$\{s\}`).style.display = s === name ? 'block' : 'none';\line 179      \});\line 180      document.querySelectorAll('.nav-item').forEach(el => el.classList.toggle('active', el.dataset.page === name));\line 181      const titles = \{\line 182        dashboard: ['Dashboard','Your clinical overview'],\line 183        patients: ['Patients','Patient registry'],\line 184        records: ['Medical Records','Records you have created'],\line 185        appointments: ['Appointments','Your scheduled appointments'],\line 186        'patient-detail': ['Patient Detail','Full patient health record']\line 187      \};\line 188      if (titles[name]) \{\line 189        document.getElementById('section-title').textContent = titles[name][0];\line 190        document.getElementById('section-subtitle').textContent = titles[name][1];\line 191      \}\line 192      if (name === 'patients') loadPatients();\line 193      if (name === 'records') loadRecords();\line 194      if (name === 'appointments') loadAppointments();\line 195    \}\line 196  \line 197    async function loadDashboard() \{\line 198      const res = await api.get('/clinician/dashboard');\line 199      if (!res || !res.ok) return;\line 200      const d = res.data.data;\line 201      document.getElementById('clin-stats').innerHTML = `\line 202        <div class="stat-card"><div class="stat-icon blue">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.my_patients\}</div><div class="label">My Patients</div></div></div>\line 203        <div class="stat-card"><div class="stat-icon yellow">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.my_appointments\}</div><div class="label">Upcoming Appointments</div></div></div>\line 204        <div class="stat-card"><div class="stat-icon green">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.records_created\}</div><div class="label">Records Created</div></div></div>\line 205      `;\line 206      document.getElementById('recent-patients').innerHTML = d.recent_patients.length ?\line 207        d.recent_patients.map(p => `\line 208          <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--gray-100);cursor:pointer;" onclick="viewPatient($\{p.id\})">\line 209            <div>\line 210              <div style="font-weight:600;font-size:13px;">$\{p.name\}</div>\line 211              <div style="font-size:12px;color:var(--gray-500);">$\{p.diagnosis||'No diagnosis'\} \u\u $\{formatDate(p.visit_date)\}</div>\line 212            </div>\line 213            <span style="color:var(--primary);font-size:12px;">View \u\u\u</span>\line 214          </div>`).join('') : emptyState('\u\u\u\u','No patients yet','');\line 215  \line 216      document.getElementById('upcoming-appts').innerHTML = d.upcoming_appointments.length ?\line 217        d.upcoming_appointments.map(a => `\line 218          <div style="padding:10px 0;border-bottom:1px solid var(--gray-100);">\line 219            <div style="font-weight:600;font-size:13px;">$\{a.patient_name\}</div>\line 220            <div style="font-size:12px;color:var(--gray-500);">$\{formatDate(a.appointment_date)\} at $\{a.appointment_time\}</div>\line 221            <div style="font-size:12px;color:var(--gray-600);margin-top:2px;">$\{a.reason||'No reason specified'\}</div>\line 222          </div>`).join('') : emptyState('\u\u\u\u','No upcoming appointments','');\line 223    \}\line 224  \line 225    async function loadPatients() \{\line 226      document.getElementById('patients-table-body').innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;">Loading...</td></tr>';\line 227      const res = await api.get('/clinician/patients');\line 228      if (!res || !res.ok) return;\line 229      allPatients = res.data.data;\line 230      renderPatients(allPatients);\line 231      populatePatientSelects();\line 232    \}\line 233  \line 234    function renderPatients(patients) \{\line 235      document.getElementById('patients-table-body').innerHTML = patients.length ?\line 236        patients.map(p => `<tr>\line 237          <td><strong>$\{p.name\}</strong></td>\line 238          <td>$\{p.email\}</td>\line 239          <td>$\{p.date_of_birth ? formatDate(p.date_of_birth) : '\u\u\u'\}</td>\line 240          <td>$\{p.gender||'\u\u\u'\}</td>\line 241          <td><span class="badge badge-info">$\{p.blood_group||'\u\u\u'\}</span></td>\line 242          <td>$\{p.phone||'\u\u\u'\}</td>\line 243          <td>$\{p.allergies||'None'\}</td>\line 244          <td><button class="btn btn-primary btn-sm" onclick="viewPatient($\{p.id\})">View</button></td>\line 245        </tr>`).join('') :\line 246        `<tr><td colspan="8">$\{emptyState('\u\u\u\u','No patients registered','')\}</td></tr>`;\line 247    \}\line 248  \line 249    function filterPatients() \{\line 250      const q = document.getElementById('patient-search').value.toLowerCase();\line 251      renderPatients(allPatients.filter(p => p.name.toLowerCase().includes(q) || p.email.toLowerCase().includes(q)));\line 252    \}\line 253  \line 254    function populatePatientSelects() \{\line 255      const opts = allPatients.map(p => `<option value="$\{p.id\}">$\{p.name\} ($\{p.email\})</option>`).join('');\line 256      document.getElementById('r-patient').innerHTML = '<option value="">Select patient...</option>' + opts;\line 257      document.getElementById('a-patient').innerHTML = '<option value="">Select patient...</option>' + opts;\line 258    \}\line 259  \line 260    async function viewPatient(patientId) \{\line 261      showSection('patient-detail');\line 262      document.getElementById('section-title').textContent = 'Patient Detail';\line 263      document.getElementById('patient-detail-content').innerHTML = '<div class="page-loader"><div class="spinner"></div><p>Loading patient data...</p></div>';\line 264  \line 265      const res = await api.get(`/clinician/patients/$\{patientId\}`);\line 266      if (!res || !res.ok) \{ document.getElementById('patient-detail-content').innerHTML = '<div class="alert alert-error">Failed to load patient data.</div>'; return; \}\line 267  \line 268      const \{ patient: p, records, appointments \} = res.data.data;\line 269      document.getElementById('patient-detail-content').innerHTML = `\line 270        <div class="card">\line 271          <div class="card-header">\line 272            <div style="display:flex;align-items:center;gap:14px;">\line 273              <div style="width:52px;height:52px;border-radius:50%;background:var(--secondary);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:18px;">$\{p.name.split(' ').map(n=>n[0]).join('').substring(0,2)\}</div>\line 274              <div><h3>$\{p.name\}</h3><p>$\{p.email\}</p></div>\line 275            </div>\line 276            <button class="btn btn-primary btn-sm" onclick="openNewRecordForPatient($\{p.id\}, '$\{p.name\}')">+ Add Record</button>\line 277          </div>\line 278          <div class="info-grid">\line 279            <div class="info-item"><label>Date of Birth</label><p>$\{p.date_of_birth ? formatDate(p.date_of_birth) : '\u\u\u'\}</p></div>\line 280            <div class="info-item"><label>Gender</label><p>$\{p.gender||'\u\u\u'\}</p></div>\line 281            <div class="info-item"><label>Blood Group</label><p>$\{p.blood_group||'\u\u\u'\}</p></div>\line 282            <div class="info-item"><label>Phone</label><p>$\{p.phone||'\u\u\u'\}</p></div>\line 283            <div class="info-item"><label>Address</label><p>$\{p.address||'\u\u\u'\}</p></div>\line 284            <div class="info-item"><label>Emergency Contact</label><p>$\{p.emergency_contact||'\u\u\u'\} $\{p.emergency_phone ? '\u\u '+p.emergency_phone : ''\}</p></div>\line 285            <div class="info-item"><label>Insurance No.</label><p>$\{p.insurance_number||'\u\u\u'\}</p></div>\line 286            <div class="info-item"><label>Allergies</label><p style="color:$\{p.allergies&&p.allergies!=='None'?'var(--danger)':'inherit'\}">$\{p.allergies||'None known'\}</p></div>\line 287          </div>\line 288        </div>\line 289  \line 290        <div class="tabs">\line 291          <div class="tab active" onclick="switchTab(this,'tab-records')">Medical Records ($\{records.length\})</div>\line 292          <div class="tab" onclick="switchTab(this,'tab-appts')">Appointments ($\{appointments.length\})</div>\line 293        </div>\line 294  \line 295        <div id="tab-records">\line 296          $\{records.length ? records.map(r => `\line 297            <div class="record-card">\line 298              <div class="record-header">\line 299                <div>\line 300                  <strong>$\{r.diagnosis||'No diagnosis'\}</strong>\line 301                  <div class="record-date">Visit: $\{formatDate(r.visit_date)\} \u\u By: $\{r.clinician_name\}</div>\line 302                </div>\line 303                <span class="badge badge-info">$\{formatDate(r.visit_date)\}</span>\line 304              </div>\line 305              <div class="record-body">\line 306                $\{r.chief_complaint ? `<div class="record-section"><div class="record-section-title">Chief Complaint</div><p>$\{r.chief_complaint\}</p></div>` : ''\}\line 307                $\{r.vital_signs ? `<div class="record-section"><div class="record-section-title">Vital Signs</div><p>$\{r.vital_signs\}</p></div>` : ''\}\line 308                $\{r.medications ? `<div class="record-section"><div class="record-section-title">Medications</div><p>$\{r.medications\}</p></div>` : ''\}\line 309                $\{r.treatment_plan ? `<div class="record-section"><div class="record-section-title">Treatment Plan</div><p>$\{r.treatment_plan\}</p></div>` : ''\}\line 310                $\{r.lab_results ? `<div class="record-section"><div class="record-section-title">Lab Results</div><p>$\{r.lab_results\}</p></div>` : ''\}\line 311                $\{r.notes ? `<div class="record-section"><div class="record-section-title">Notes</div><p>$\{r.notes\}</p></div>` : ''\}\line 312              </div>\line 313            </div>`).join('') : emptyState('\u\u\u\u','No medical records','No records have been created for this patient yet.')\}\line 314        </div>\line 315  \line 316        <div id="tab-appts" style="display:none;">\line 317          $\{appointments.length ? `\line 318            <div class="table-container"><table>\line 319              <thead><tr><th>Date</th><th>Time</th><th>Clinician</th><th>Reason</th><th>Status</th></tr></thead>\line 320              <tbody>$\{appointments.map(a => `<tr>\line 321                <td>$\{formatDate(a.appointment_date)\}</td>\line 322                <td>$\{a.appointment_time\}</td>\line 323                <td>$\{a.clinician_name\}</td>\line 324                <td>$\{a.reason||'\u\u\u'\}</td>\line 325                <td>$\{statusBadge(a.status)\}</td>\line 326              </tr>`).join('')\}</tbody>\line 327            </table></div>` : emptyState('\u\u\u\u','No appointments','No appointments recorded for this patient.')\}\line 328        </div>\line 329      `;\line 330    \}\line 331  \line 332    function switchTab(el, tabId) \{\line 333      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));\line 334      el.classList.add('active');\line 335      ['tab-records','tab-appts'].forEach(id => \{\line 336        const el2 = document.getElementById(id);\line 337        if (el2) el2.style.display = id === tabId ? 'block' : 'none';\line 338      \});\line 339    \}\line 340  \line 341    async function loadRecords() \{\line 342      document.getElementById('records-list').innerHTML = '<div class="page-loader"><div class="spinner"></div></div>';\line 343      const res = await api.get('/clinician/records');\line 344      if (!res || !res.ok) return;\line 345      const records = res.data.data;\line 346      document.getElementById('records-list').innerHTML = records.length ?\line 347        records.map(r => `\line 348          <div class="record-card">\line 349            <div class="record-header">\line 350              <div>\line 351                <strong>$\{r.patient_name\}</strong>\line 352                <div class="record-date">$\{formatDate(r.visit_date)\} \u\u $\{r.diagnosis||'No diagnosis'\}</div>\line 353              </div>\line 354              <span class="badge badge-info">$\{formatDate(r.visit_date)\}</span>\line 355            </div>\line 356            <div class="info-grid" style="margin-top:10px;">\line 357              $\{r.chief_complaint ? `<div class="info-item"><label>Complaint</label><p>$\{r.chief_complaint\}</p></div>` : ''\}\line 358              $\{r.vital_signs ? `<div class="info-item"><label>Vitals</label><p>$\{r.vital_signs\}</p></div>` : ''\}\line 359              $\{r.medications ? `<div class="info-item"><label>Medications</label><p>$\{r.medications\}</p></div>` : ''\}\line 360              $\{r.treatment_plan ? `<div class="info-item"><label>Treatment</label><p>$\{r.treatment_plan\}</p></div>` : ''\}\line 361            </div>\line 362          </div>`).join('') : emptyState('\u\u\u\u','No records','You have not created any records yet.');\line 363    \}\line 364  \line 365    async function loadAppointments() \{\line 366      document.getElementById('appts-table-body').innerHTML = '<tr><td colspan="6" style="text-align:center;padding:30px;">Loading...</td></tr>';\line 367      const res = await api.get('/clinician/appointments');\line 368      if (!res || !res.ok) return;\line 369      const apts = res.data.data;\line 370      document.getElementById('appts-table-body').innerHTML = apts.length ?\line 371        apts.map(a => `<tr>\line 372          <td><strong>$\{a.patient_name\}</strong><br><span style="font-size:11px;color:var(--gray-500);">$\{a.patient_email\}</span></td>\line 373          <td>$\{formatDate(a.appointment_date)\}</td>\line 374          <td>$\{a.appointment_time\}</td>\line 375          <td>$\{a.reason||'\u\u\u'\}</td>\line 376          <td>$\{statusBadge(a.status)\}</td>\line 377          <td>\line 378            $\{a.status==='scheduled' ? `\line 379              <button class="btn btn-success btn-sm" onclick="updateApptStatus($\{a.id\},'completed')">Complete</button>\line 380              <button class="btn btn-danger btn-sm" onclick="updateApptStatus($\{a.id\},'cancelled')">Cancel</button>\line 381            ` : '\u\u\u'\}\line 382          </td>\line 383        </tr>`).join('') :\line 384        `<tr><td colspan="6">$\{emptyState('\u\u\u\u','No appointments','')\}</td></tr>`;\line 385    \}\line 386  \line 387    function openNewRecordModal() \{\line 388      if (!allPatients.length) \{ loadPatients().then(() => openNewRecordModal()); return; \}\line 389      ['r-patient','r-date','r-complaint','r-diagnosis','r-vitals','r-medications','r-treatment','r-labs','r-notes'].forEach(id => \{\line 390        const el = document.getElementById(id);\line 391        if (el) el.value = '';\line 392      \});\line 393      document.getElementById('r-date').value = new Date().toISOString().split('T')[0];\line 394      document.getElementById('record-form-alert').style.display = 'none';\line 395      openModal('record-modal');\line 396    \}\line 397  \line 398    function openNewRecordForPatient(patientId, patientName) \{\line 399      openNewRecordModal();\line 400      document.getElementById('r-patient').value = patientId;\line 401    \}\line 402  \line 403    async function saveRecord() \{\line 404      const alertDiv = document.getElementById('record-form-alert');\line 405      const patient_id = document.getElementById('r-patient').value;\line 406      const visit_date = document.getElementById('r-date').value;\line 407      const diagnosis = document.getElementById('r-diagnosis').value.trim();\line 408  \line 409      if (!patient_id || !visit_date || !diagnosis) \{\line 410        alertDiv.className = 'alert alert-error';\line 411        alertDiv.textContent = 'Patient, visit date and diagnosis are required.';\line 412        alertDiv.style.display = 'flex';\line 413        return;\line 414      \}\line 415  \line 416      const res = await api.post('/clinician/records', \{\line 417        patient_id, visit_date,\line 418        chief_complaint: document.getElementById('r-complaint').value,\line 419        diagnosis,\line 420        vital_signs: document.getElementById('r-vitals').value,\line 421        medications: document.getElementById('r-medications').value,\line 422        treatment_plan: document.getElementById('r-treatment').value,\line 423        lab_results: document.getElementById('r-labs').value,\line 424        notes: document.getElementById('r-notes').value\line 425      \});\line 426  \line 427      if (res && res.ok) \{\line 428        closeModal('record-modal');\line 429        showToast('Medical record saved successfully.', 'success');\line 430        loadRecords();\line 431      \} else \{\line 432        alertDiv.className = 'alert alert-error';\line 433        alertDiv.textContent = res?.data?.message || 'Failed to save record.';\line 434        alertDiv.style.display = 'flex';\line 435      \}\line 436    \}\line 437  \line 438    function openApptModal() \{\line 439      if (!allPatients.length) \{ loadPatients().then(() => openApptModal()); return; \}\line 440      ['a-patient','a-date','a-time','a-reason','a-notes'].forEach(id => \{\line 441        const el = document.getElementById(id);\line 442        if (el) el.value = '';\line 443      \});\line 444      document.getElementById('appt-form-alert').style.display = 'none';\line 445      openModal('appt-modal');\line 446    \}\line 447  \line 448    async function saveAppt() \{\line 449      const alertDiv = document.getElementById('appt-form-alert');\line 450      const patient_id = document.getElementById('a-patient').value;\line 451      const appointment_date = document.getElementById('a-date').value;\line 452      const appointment_time = document.getElementById('a-time').value;\line 453  \line 454      if (!patient_id || !appointment_date || !appointment_time) \{\line 455        alertDiv.className = 'alert alert-error';\line 456        alertDiv.textContent = 'Patient, date and time are required.';\line 457        alertDiv.style.display = 'flex';\line 458        return;\line 459      \}\line 460  \line 461      const res = await api.post('/clinician/appointments', \{\line 462        patient_id, appointment_date, appointment_time,\line 463        reason: document.getElementById('a-reason').value,\line 464        notes: document.getElementById('a-notes').value\line 465      \});\line 466  \line 467      if (res && res.ok) \{\line 468        closeModal('appt-modal');\line 469        showToast('Appointment scheduled.', 'success');\line 470        loadAppointments();\line 471      \} else \{\line 472        alertDiv.className = 'alert alert-error';\line 473        alertDiv.textContent = res?.data?.message || 'Failed to schedule.';\line 474        alertDiv.style.display = 'flex';\line 475      \}\line 476    \}\line 477  \line 478    async function updateApptStatus(id, status) \{\line 479      const res = await api.put(`/clinician/appointments/$\{id\}/status`, \{ status \});\line 480      if (res && res.ok) \{ showToast(`Appointment marked as $\{status\}.`, 'success'); loadAppointments(); \}\line 481      else showToast('Failed to update status.', 'error');\line 482    \}\line 483  \line 484    loadDashboard();\line 485    loadPatients();\line 486  </script>\line 487  </body>\line 488  </html>\line 489  \par
