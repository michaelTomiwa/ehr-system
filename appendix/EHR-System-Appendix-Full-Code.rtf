\pard\b\f0\fs25\sa220 Appendix B.1: System Login Page\par
\pard\i\f0\fs20\sa100 File Path: frontend/index.html\par
\pard\i\f0\fs20\sa100 Section Description: Initial authentication interface for all user roles.\par
\pard\f0\fs20\sa100 What this file does: This file defines the main entry page that users see before accessing the system.\par
\pard\f0\fs20\sa100 How this file is used in the system: It is served as the default frontend page. Users enter their email and password here, the page sends the credentials to /api/auth/login, stores the returned JWT and user object in localStorage, and redirects each user to the correct role-specific dashboard.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Contains the login form used by all user categories.\par
\pard\f0\fs19\li360\sa70 - Provides demo-account shortcuts for evaluation and demonstration.\par
\pard\f0\fs19\li360\sa70 - Redirects already authenticated users directly to the dashboard that matches their role.\par
\pard\f0\fs19\li360\sa70 - Displays authentication feedback when login succeeds or fails.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  <!DOCTYPE html>\line   2  <html lang="en">\line   3  <head>\line   4    <meta charset="UTF-8">\line   5    <meta name="viewport" content="width=device-width, initial-scale=1.0">\line   6    <title>EHR System \u\u\u Login | Secure Cloud-Based EHR with RBAC</title>\line   7    <link rel="stylesheet" href="/assets/css/style.css">\line   8    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">\line   9  </head>\line  10  <body class="login-page">\line  11  \line  12    <div class="login-container">\line  13      <div class="login-header">\line  14        <div class="logo-icon">\u\u\u\u</div>\line  15        <h1>SecureEHR System</h1>\line  16        <p>Secure Cloud-Based Electronic Health Records</p>\line  17        <p style="font-size:11px; opacity:0.7; margin-top:4px;">Role-Based Access Control (RBAC)</p>\line  18      </div>\line  19  \line  20      <div class="login-body">\line  21        <div id="login-alert" style="display:none;"></div>\line  22  \line  23        <form id="login-form">\line  24          <div class="form-group">\line  25            <label>Email Address</label>\line  26            <input type="email" id="email" placeholder="Enter your email" required autocomplete="username">\line  27          </div>\line  28          <div class="form-group">\line  29            <label>Password</label>\line  30            <input type="password" id="password" placeholder="Enter your password" required autocomplete="current-password">\line  31          </div>\line  32          <button type="submit" class="btn btn-primary btn-full" id="login-btn">\line  33            Sign In to EHR System\line  34          </button>\line  35        </form>\line  36  \line  37        <div class="demo-accounts">\line  38          <h4>Demo Accounts (Password: Password123!)</h4>\line  39          <div class="demo-account" onclick="fillDemo('admin@ehrsystem.com')">\line  40            <span class="role-badge badge badge-admin">Admin</span>\line  41            <span class="email">admin@ehrsystem.com</span>\line  42            <span style="font-size:11px; color:#9ca3af;">Click to fill</span>\line  43          </div>\line  44          <div class="demo-account" onclick="fillDemo('amina.okafor@ehrsystem.com')">\line  45            <span class="role-badge badge badge-clinician">Clinician</span>\line  46            <span class="email">amina.okafor@ehrsystem.com</span>\line  47            <span style="font-size:11px; color:#9ca3af;">Click to fill</span>\line  48          </div>\line  49          <div class="demo-account" onclick="fillDemo('james.adeyemi@ehrsystem.com')">\line  50            <span class="role-badge badge badge-clinician">Clinician</span>\line  51            <span class="email">james.adeyemi@ehrsystem.com</span>\line  52            <span style="font-size:11px; color:#9ca3af;">Click to fill</span>\line  53          </div>\line  54          <div class="demo-account" onclick="fillDemo('emeka.chukwu@gmail.com')">\line  55            <span class="role-badge badge badge-patient">Patient</span>\line  56            <span class="email">emeka.chukwu@gmail.com</span>\line  57            <span style="font-size:11px; color:#9ca3af;">Click to fill</span>\line  58          </div>\line  59          <div class="demo-account" onclick="fillDemo('ngozi.obi@gmail.com')">\line  60            <span class="role-badge badge badge-patient">Patient</span>\line  61            <span class="email">ngozi.obi@gmail.com</span>\line  62            <span style="font-size:11px; color:#9ca3af;">Click to fill</span>\line  63          </div>\line  64        </div>\line  65  \line  66        <p style="text-align:center; font-size:11px; color:var(--gray-500); margin-top:16px;">\line  67          University of the West of Scotland \u\u MSc Computer Science<br>\line  68          Design and Implementation of Secure Cloud-Based EHR with RBAC\line  69        </p>\line  70      </div>\line  71    </div>\line  72  \line  73  <script src="/assets/js/app.js"></script>\line  74  <script>\line  75    // Redirect if already logged in\line  76    if (isLoggedIn()) \{\line  77      const role = getUser().role;\line  78      window.location.href = `/pages/$\{role\}/dashboard.html`;\line  79    \}\line  80  \line  81    function fillDemo(email) \{\line  82      document.getElementById('email').value = email;\line  83      document.getElementById('password').value = 'Password123!';\line  84    \}\line  85  \line  86    document.getElementById('login-form').addEventListener('submit', async (e) => \{\line  87      e.preventDefault();\line  88      const btn = document.getElementById('login-btn');\line  89      const alertDiv = document.getElementById('login-alert');\line  90  \line  91      btn.disabled = true;\line  92      btn.innerHTML = '<span class="loading-spinner"></span> Authenticating...';\line  93      alertDiv.style.display = 'none';\line  94  \line  95      const email = document.getElementById('email').value.trim();\line  96      const password = document.getElementById('password').value;\line  97  \line  98      const result = await api.post('/auth/login', \{ email, password \});\line  99  \line 100      if (result && result.ok) \{\line 101        localStorage.setItem('ehr_token', result.data.token);\line 102        localStorage.setItem('ehr_user', JSON.stringify(result.data.user));\line 103        showToast(`Welcome, $\{result.data.user.name\}!`, 'success');\line 104        setTimeout(() => \{\line 105          window.location.href = `/pages/$\{result.data.user.role\}/dashboard.html`;\line 106        \}, 500);\line 107      \} else \{\line 108        const msg = result?.data?.message || 'Login failed. Please check your credentials.';\line 109        alertDiv.className = 'alert alert-error';\line 110        alertDiv.innerHTML = `\u\u\u\u $\{msg\}`;\line 111        alertDiv.style.display = 'flex';\line 112        btn.disabled = false;\line 113        btn.innerHTML = 'Sign In to EHR System';\line 114      \}\line 115    \});\line 116  </script>\line 117  </body>\line 118  </html>\line 119  \par
\pard\cb0\par
