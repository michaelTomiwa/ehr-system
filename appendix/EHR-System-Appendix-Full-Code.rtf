\pard\b\f0\fs25\sa220 Appendix B.7: Patient Dashboard\par
\pard\i\f0\fs20\sa100 File Path: frontend/pages/patient/dashboard.html\par
\pard\i\f0\fs20\sa100 Section Description: Patient frontend for profile, records, appointments, and health summary.\par
\pard\f0\fs20\sa100 What this file does: This file defines the patient portal through which patients can review their own information securely.\par
\pard\f0\fs20\sa100 How this file is used in the system: After patient login, the page loads the patient summary, personal profile, personal medical records, and personal appointments using the patient-only backend endpoints. It is designed to demonstrate privacy-preserving self-service access under the RBAC model.\par
\pard\b\f0\fs20\sa120 Main responsibilities implemented in this file:\par
\pard\f0\fs19\li360\sa70 - Provides a home summary with recent visit and upcoming appointment information.\par
\pard\f0\fs19\li360\sa70 - Displays personal demographic and emergency-contact details.\par
\pard\f0\fs19\li360\sa70 - Shows the patient\u\u\us medical history and medication information.\par
\pard\f0\fs19\li360\sa70 - Allows filtering of appointments by status inside the portal.\par
\pard\sa120\par
\pard\b\f0\fs20\sa120 Full source code listing:\par
\pard\li240\ri120\cb1\f1\fs18\sa80
  1  <!DOCTYPE html>\line   2  <html lang="en">\line   3  <head>\line   4    <meta charset="UTF-8">\line   5    <meta name="viewport" content="width=device-width, initial-scale=1.0">\line   6    <title>Patient Portal \u\u\u SecureEHR</title>\line   7    <link rel="stylesheet" href="/assets/css/style.css">\line   8    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">\line   9  </head>\line  10  <body>\line  11  <div class="dashboard-layout">\line  12  \line  13    <aside class="sidebar">\line  14      <div class="sidebar-header">\line  15        <div class="sidebar-logo">\line  16          <div class="logo-icon">\u\u\u\u</div>\line  17          <div class="sidebar-logo-text"><h2>SecureEHR</h2><p>Patient Portal</p></div>\line  18        </div>\line  19      </div>\line  20      <div class="sidebar-user">\line  21        <div class="user-avatar"></div>\line  22        <div class="sidebar-user-info">\line  23          <div class="name sidebar-user-name"></div>\line  24          <div class="role sidebar-user-role"></div>\line  25        </div>\line  26      </div>\line  27      <nav class="sidebar-nav">\line  28        <div class="nav-section-title">My Health</div>\line  29        <div class="nav-item active" data-page="dashboard" onclick="showSection('dashboard')"><span class="icon">\u\u\u\u</span> Home</div>\line  30        <div class="nav-item" data-page="profile" onclick="showSection('profile')"><span class="icon">\u\u\u\u</span> My Profile</div>\line  31        <div class="nav-item" data-page="records" onclick="showSection('records')"><span class="icon">\u\u\u\u</span> Medical Records</div>\line  32        <div class="nav-item" data-page="appointments" onclick="showSection('appointments')"><span class="icon">\u\u\u\u</span> Appointments</div>\line  33      </nav>\line  34      <div class="sidebar-footer">\line  35        <button class="logout-btn" onclick="logout()"><span>\u\u\u\u</span> Sign Out</button>\line  36      </div>\line  37    </aside>\line  38  \line  39    <main class="main-content">\line  40      <div class="topbar">\line  41        <div class="topbar-title"><h1 id="section-title">Home</h1><p id="section-subtitle">Your personal health portal</p></div>\line  42        <div style="display:flex; align-items:center; gap:12px;">\line  43          <span class="badge badge-patient">Patient</span>\line  44          <span class="topbar-user-name" style="font-weight:600; font-size:13px;"></span>\line  45        </div>\line  46      </div>\line  47  \line  48      <div class="page-content">\line  49  \line  50        <!-- HOME / SUMMARY -->\line  51        <section id="sec-dashboard">\line  52          <div class="alert alert-info" style="margin-bottom:20px;">\line  53            \u\u\u\u <strong>Secure Access:</strong> Your health records are protected by Role-Based Access Control. Only you and authorised healthcare professionals can view your data.\line  54          </div>\line  55          <div class="stats-grid" id="summary-stats"></div>\line  56          <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-top:4px;">\line  57            <div class="card">\line  58              <div class="card-header"><div><h3>Last Visit</h3><p>Most recent clinical encounter</p></div></div>\line  59              <div id="last-visit-content"></div>\line  60            </div>\line  61            <div class="card">\line  62              <div class="card-header"><div><h3>Next Appointment</h3><p>Your upcoming scheduled visit</p></div></div>\line  63              <div id="next-appt-content"></div>\line  64            </div>\line  65          </div>\line  66          <div class="card" style="margin-top:20px;">\line  67            <div class="card-header"><div><h3>Active Medications</h3><p>Medications from your most recent visit</p></div></div>\line  68            <div id="medications-content"></div>\line  69          </div>\line  70        </section>\line  71  \line  72        <!-- PROFILE -->\line  73        <section id="sec-profile" style="display:none;">\line  74          <div class="card">\line  75            <div class="card-header"><h3>My Profile</h3></div>\line  76            <div id="profile-content"><div class="page-loader"><div class="spinner"></div></div></div>\line  77          </div>\line  78        </section>\line  79  \line  80        <!-- MEDICAL RECORDS -->\line  81        <section id="sec-records" style="display:none;">\line  82          <div class="card">\line  83            <div class="card-header"><div><h3>My Medical Records</h3><p>Your complete health history</p></div></div>\line  84            <div class="alert alert-info" style="margin-bottom:16px;">\line  85              You can view your medical records here. If you believe there are any errors, please contact your clinician.\line  86            </div>\line  87            <div id="patient-records-list"><div class="page-loader"><div class="spinner"></div></div></div>\line  88          </div>\line  89        </section>\line  90  \line  91        <!-- APPOINTMENTS -->\line  92        <section id="sec-appointments" style="display:none;">\line  93          <div class="card">\line  94            <div class="card-header"><div><h3>My Appointments</h3><p>Your scheduled and past appointments</p></div></div>\line  95            <div class="tabs">\line  96              <div class="tab active" onclick="filterAppts(this,'all')">All</div>\line  97              <div class="tab" onclick="filterAppts(this,'scheduled')">Upcoming</div>\line  98              <div class="tab" onclick="filterAppts(this,'completed')">Completed</div>\line  99            </div>\line 100            <div class="table-container">\line 101              <table>\line 102                <thead><tr><th>Date</th><th>Time</th><th>Clinician</th><th>Reason</th><th>Status</th></tr></thead>\line 103                <tbody id="patient-appts-body"></tbody>\line 104              </table>\line 105            </div>\line 106          </div>\line 107        </section>\line 108  \line 109      </div>\line 110    </main>\line 111  </div>\line 112  \line 113  <script src="/assets/js/app.js"></script>\line 114  <script>\line 115    let allAppts = [];\line 116    if (!requireAuth(['patient'])) throw new Error('auth');\line 117    initSidebar('dashboard');\line 118  \line 119    function showSection(name) \{\line 120      ['dashboard','profile','records','appointments'].forEach(s => \{\line 121        document.getElementById(`sec-$\{s\}`).style.display = s === name ? 'block' : 'none';\line 122      \});\line 123      document.querySelectorAll('.nav-item').forEach(el => el.classList.toggle('active', el.dataset.page === name));\line 124      const titles = \{\line 125        dashboard: ['Home','Your personal health portal'],\line 126        profile: ['My Profile','Your personal and medical details'],\line 127        records: ['Medical Records','Your complete health history'],\line 128        appointments: ['Appointments','Your scheduled and past visits']\line 129      \};\line 130      document.getElementById('section-title').textContent = titles[name][0];\line 131      document.getElementById('section-subtitle').textContent = titles[name][1];\line 132      if (name === 'profile') loadProfile();\line 133      if (name === 'records') loadRecords();\line 134      if (name === 'appointments') loadAppointments();\line 135    \}\line 136  \line 137    async function loadSummary() \{\line 138      const res = await api.get('/patient/summary');\line 139      if (!res || !res.ok) return;\line 140      const d = res.data.data;\line 141  \line 142      document.getElementById('summary-stats').innerHTML = `\line 143        <div class="stat-card"><div class="stat-icon blue">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.total_visits\}</div><div class="label">Total Visits</div></div></div>\line 144        <div class="stat-card"><div class="stat-icon yellow">\u\u\u\u</div><div class="stat-info"><div class="value">$\{d.upcoming_appointments\}</div><div class="label">Upcoming Appointments</div></div></div>\line 145      `;\line 146  \line 147      document.getElementById('last-visit-content').innerHTML = d.last_visit ?\line 148        `<div style="padding:10px 0;">\line 149          <div style="font-size:22px; font-weight:800; color:var(--gray-900); margin-bottom:4px;">$\{formatDate(d.last_visit.visit_date)\}</div>\line 150          <div style="font-size:14px; color:var(--gray-600);">$\{d.last_visit.diagnosis||'No diagnosis recorded'\}</div>\line 151          <div style="margin-top:12px;"><button class="btn btn-outline btn-sm" onclick="showSection('records')">View Records \u\u\u</button></div>\line 152        </div>` : emptyState('\u\u\u\u','No visits yet','You have no recorded clinical visits.');\line 153  \line 154      document.getElementById('next-appt-content').innerHTML = d.next_appointment ?\line 155        `<div style="padding:10px 0;">\line 156          <div style="font-size:18px; font-weight:800; color:var(--primary); margin-bottom:4px;">$\{formatDate(d.next_appointment.appointment_date)\} at $\{d.next_appointment.appointment_time\}</div>\line 157          <div style="font-size:14px; color:var(--gray-600); margin-bottom:4px;">With: <strong>$\{d.next_appointment.clinician_name\}</strong></div>\line 158          <div style="font-size:13px; color:var(--gray-500);">$\{d.next_appointment.reason||'Routine visit'\}</div>\line 159        </div>` : emptyState('\u\u\u\u','No upcoming appointments','');\line 160  \line 161      document.getElementById('medications-content').innerHTML = d.active_medications?.medications ?\line 162        `<div style="background:var(--gray-50); border-radius:8px; padding:14px; border:1px solid var(--gray-200);">\line 163          <p style="font-size:14px; color:var(--gray-800); line-height:1.6;">$\{d.active_medications.medications\}</p>\line 164          <p style="font-size:11px; color:var(--gray-400); margin-top:8px;">From your most recent visit. Always follow your clinician's instructions.</p>\line 165        </div>` : emptyState('\u\u\u\u','No medications','No active medications from recent visits.');\line 166    \}\line 167  \line 168    async function loadProfile() \{\line 169      const res = await api.get('/patient/profile');\line 170      if (!res || !res.ok) return;\line 171      const p = res.data.data;\line 172      document.getElementById('profile-content').innerHTML = `\line 173        <div style="display:flex; align-items:center; gap:16px; margin-bottom:24px; padding-bottom:20px; border-bottom:1px solid var(--gray-100);">\line 174          <div style="width:64px;height:64px;border-radius:50%;background:var(--secondary);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:22px;">$\{p.name.split(' ').map(n=>n[0]).join('').substring(0,2)\}</div>\line 175          <div>\line 176            <h2 style="font-size:20px;">$\{p.name\}</h2>\line 177            <p style="color:var(--gray-500);">$\{p.email\}</p>\line 178            <span class="badge badge-patient" style="margin-top:4px;">Patient</span>\line 179          </div>\line 180        </div>\line 181        <div class="info-grid">\line 182          <div class="info-item"><label>Date of Birth</label><p>$\{p.date_of_birth ? formatDate(p.date_of_birth) : '\u\u\u'\}</p></div>\line 183          <div class="info-item"><label>Gender</label><p>$\{p.gender||'\u\u\u'\}</p></div>\line 184          <div class="info-item"><label>Blood Group</label><p>$\{p.blood_group||'\u\u\u'\}</p></div>\line 185          <div class="info-item"><label>Phone</label><p>$\{p.phone||'\u\u\u'\}</p></div>\line 186          <div class="info-item"><label>Address</label><p>$\{p.address||'\u\u\u'\}</p></div>\line 187          <div class="info-item"><label>Emergency Contact</label><p>$\{p.emergency_contact||'\u\u\u'\}</p></div>\line 188          <div class="info-item"><label>Emergency Phone</label><p>$\{p.emergency_phone||'\u\u\u'\}</p></div>\line 189          <div class="info-item"><label>Insurance Number</label><p>$\{p.insurance_number||'\u\u\u'\}</p></div>\line 190          <div class="info-item"><label style="color:var(--danger);">Known Allergies</label><p style="color:$\{p.allergies&&p.allergies!=='None'?'var(--danger)':'inherit'\}">$\{p.allergies||'None known'\}</p></div>\line 191          <div class="info-item"><label>Member Since</label><p>$\{formatDate(p.created_at)\}</p></div>\line 192          <div class="info-item"><label>Last Login</label><p>$\{p.last_login ? formatDateTime(p.last_login) : '\u\u\u'\}</p></div>\line 193        </div>\line 194      `;\line 195    \}\line 196  \line 197    async function loadRecords() \{\line 198      const res = await api.get('/patient/records');\line 199      if (!res || !res.ok) return;\line 200      const records = res.data.data;\line 201      document.getElementById('patient-records-list').innerHTML = records.length ?\line 202        records.map(r => `\line 203          <div class="record-card">\line 204            <div class="record-header">\line 205              <div>\line 206                <strong style="font-size:15px;">$\{r.diagnosis||'Visit Record'\}</strong>\line 207                <div class="record-date">Visit Date: $\{formatDate(r.visit_date)\} \u\u Clinician: $\{r.clinician_name\}</div>\line 208              </div>\line 209              <span class="badge badge-info">$\{formatDate(r.visit_date)\}</span>\line 210            </div>\line 211            <div class="record-body">\line 212              $\{r.chief_complaint ? `<div class="record-section"><div class="record-section-title">Chief Complaint</div><p>$\{r.chief_complaint\}</p></div>` : ''\}\line 213              $\{r.vital_signs ? `<div class="record-section"><div class="record-section-title">Vital Signs</div><p>$\{r.vital_signs\}</p></div>` : ''\}\line 214              $\{r.medications ? `<div class="record-section"><div class="record-section-title">Medications Prescribed</div><p>$\{r.medications\}</p></div>` : ''\}\line 215              $\{r.treatment_plan ? `<div class="record-section"><div class="record-section-title">Treatment Plan</div><p>$\{r.treatment_plan\}</p></div>` : ''\}\line 216              $\{r.lab_results ? `<div class="record-section"><div class="record-section-title">Laboratory Results</div><p>$\{r.lab_results\}</p></div>` : ''\}\line 217              $\{r.notes ? `<div class="record-section"><div class="record-section-title">Clinical Notes</div><p>$\{r.notes\}</p></div>` : ''\}\line 218            </div>\line 219            <div style="font-size:11px; color:var(--gray-400); margin-top:10px; padding-top:10px; border-top:1px solid var(--gray-100);">\line 220              Record created: $\{formatDateTime(r.created_at)\} $\{r.updated_at !== r.created_at ? '\u\u Updated: '+formatDateTime(r.updated_at) : ''\}\line 221            </div>\line 222          </div>`).join('') :\line 223        emptyState('\u\u\u\u','No medical records','Your health records will appear here once your clinician adds them.');\line 224    \}\line 225  \line 226    async function loadAppointments() \{\line 227      const res = await api.get('/patient/appointments');\line 228      if (!res || !res.ok) return;\line 229      allAppts = res.data.data;\line 230      renderAppts(allAppts);\line 231    \}\line 232  \line 233    function renderAppts(appts) \{\line 234      document.getElementById('patient-appts-body').innerHTML = appts.length ?\line 235        appts.map(a => `<tr>\line 236          <td><strong>$\{formatDate(a.appointment_date)\}</strong></td>\line 237          <td>$\{a.appointment_time\}</td>\line 238          <td>$\{a.clinician_name\}</td>\line 239          <td>$\{a.reason||'\u\u\u'\}</td>\line 240          <td>$\{statusBadge(a.status)\}</td>\line 241        </tr>`).join('') :\line 242        `<tr><td colspan="5">$\{emptyState('\u\u\u\u','No appointments','')\}</td></tr>`;\line 243    \}\line 244  \line 245    function filterAppts(el, filter) \{\line 246      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));\line 247      el.classList.add('active');\line 248      renderAppts(filter === 'all' ? allAppts : allAppts.filter(a => a.status === filter));\line 249    \}\line 250  \line 251    loadSummary();\line 252  </script>\line 253  </body>\line 254  </html>\line 255  \par
